<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ClinicApp.ViewModels"
             x:Class="ClinicApp.Views.AppointmentPage"
             Title="Appointments"
             BackgroundColor="#F5F5F5">

    <RefreshView Command="{Binding RefreshCommand}"
             IsRefreshing="{Binding IsRefreshing}">
        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="16">

                <!-- ── PENDING SECTION ── -->
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Pending Approval"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="#E65100"
                               VerticalOptions="Center"/>
                        <Border Grid.Column="1"
                                BackgroundColor="#E65100"
                                StrokeShape="RoundRectangle 12"
                                Padding="8,2">
                            <Label Text="{Binding PendingCount}"
                                   TextColor="White" FontSize="12"
                                   FontAttributes="Bold"/>
                        </Border>
                    </Grid>
                    <Label Text="No pending bookings"
                           TextColor="Gray" FontSize="13">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label"
                                         Binding="{Binding HasPending}"
                                         Value="True">
                                <Setter Property="IsVisible" Value="False"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>

                    <CollectionView ItemsSource="{Binding PendingBookings}"
                                    IsVisible="{Binding HasPending}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Margin="0,4" Padding="14" CornerRadius="12"
                                       BorderColor="#FFE0B2" BackgroundColor="White"
                                       HasShadow="True">
                                    <VerticalStackLayout Spacing="4">

                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Text="{Binding FullName}"
                                                   FontSize="15" FontAttributes="Bold"
                                                   VerticalOptions="Center"/>
                                            <Border Grid.Column="1"
                                                    BackgroundColor="#FFF3E0"
                                                    StrokeShape="RoundRectangle 8"
                                                    Padding="6,2">
                                                <Label Text="PENDING" FontSize="10"
                                                       TextColor="#E65100"
                                                       FontAttributes="Bold"/>
                                            </Border>
                                        </Grid>

                                        <Label Text="{Binding Service}"
                                               FontSize="13" TextColor="#1565C0"/>
                                        <Label Text="{Binding AppointmentDate, StringFormat='{0:MMM dd, yyyy  h:mm tt}'}"
                                               FontSize="12" TextColor="Gray"/>
                                        <Label Text="{Binding Phone}"
                                               FontSize="12" TextColor="Gray"/>
                                        <Label Text="{Binding Notes}"
                                               FontSize="12" TextColor="Gray"
                                               IsVisible="{Binding Notes, Converter={StaticResource StringToBoolConverter}}"/>

                                        <HorizontalStackLayout Spacing="8" Margin="0,8,0,0">
                                            <Button Text="✓  Approve"
                                                    BackgroundColor="#2E7D32"
                                                    TextColor="White"
                                                    CornerRadius="8"
                                                    FontSize="13"
                                                    HeightRequest="38"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AppointmentViewModel}}, Path=ApproveCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            <Button Text="↺  Reschedule"
                                                    BackgroundColor="#1565C0"
                                                    TextColor="White"
                                                    CornerRadius="8"
                                                    FontSize="13"
                                                    HeightRequest="38"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AppointmentViewModel}}, Path=RescheduleCommand}"
                                                    CommandParameter="{Binding .}"/>
                                        </HorizontalStackLayout>

                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- ── DIVIDER ── -->
                <BoxView HeightRequest="1" Color="#E0E0E0" Margin="0,4"/>

                <!-- ── APPROVED SECTION ── -->
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Approved"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="#2E7D32"
                               VerticalOptions="Center"/>
                        <Border Grid.Column="1"
                                BackgroundColor="#2E7D32"
                                StrokeShape="RoundRectangle 12"
                                Padding="8,2">
                            <Label Text="{Binding ApprovedCount}"
                                   TextColor="White" FontSize="12"
                                   FontAttributes="Bold"/>
                        </Border>
                    </Grid>
                    <Label Text="No approved bookings"
                           TextColor="Gray" FontSize="13">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label"
                                         Binding="{Binding HasApproved}"
                                         Value="True">
                                <Setter Property="IsVisible" Value="False"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>

                    <CollectionView ItemsSource="{Binding ApprovedBookings}"
                                    IsVisible="{Binding HasApproved}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Margin="0,4" Padding="14" CornerRadius="12"
                                       BorderColor="#C8E6C9" BackgroundColor="White"
                                       HasShadow="True">
                                    <VerticalStackLayout Spacing="4">

                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Text="{Binding FullName}"
                                                   FontSize="15" FontAttributes="Bold"
                                                   VerticalOptions="Center"/>
                                            <Border Grid.Column="1"
                                                    BackgroundColor="#E8F5E9"
                                                    StrokeShape="RoundRectangle 8"
                                                    Padding="6,2">
                                                <Label Text="APPROVED" FontSize="10"
                                                       TextColor="#2E7D32"
                                                       FontAttributes="Bold"/>
                                            </Border>
                                        </Grid>

                                        <Label Text="{Binding Service}"
                                               FontSize="13" TextColor="#1565C0"/>
                                        <Label Text="{Binding AppointmentDate, StringFormat='{0:MMM dd, yyyy  h:mm tt}'}"
                                               FontSize="12" TextColor="Gray"/>
                                        <Label Text="{Binding Phone}"
                                               FontSize="12" TextColor="Gray"/>

                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- ── DIVIDER ── -->
                <BoxView HeightRequest="1" Color="#E0E0E0" Margin="0,4"/>

                <!-- ── RESCHEDULED SECTION ── -->
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="For Rescheduling"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="#1565C0"
                               VerticalOptions="Center"/>
                        <Border Grid.Column="1"
                                BackgroundColor="#1565C0"
                                StrokeShape="RoundRectangle 12"
                                Padding="8,2">
                            <Label Text="{Binding RescheduledCount}"
                                   TextColor="White" FontSize="12"
                                   FontAttributes="Bold"/>
                        </Border>
                    </Grid>

                    <Label Text="No reschedule bookings"
                           TextColor="Gray" FontSize="13">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label"
                                         Binding="{Binding HasRescheduled}"
                                         Value="True">
                                <Setter Property="IsVisible" Value="False"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>

                    <CollectionView ItemsSource="{Binding RescheduledBookings}"
                                    IsVisible="{Binding HasRescheduled}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Margin="0,4" Padding="14" CornerRadius="12"
                                       BorderColor="#BBDEFB" BackgroundColor="White"
                                       HasShadow="True">
                                    <VerticalStackLayout Spacing="4">

                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Text="{Binding FullName}"
                                                   FontSize="15" FontAttributes="Bold"
                                                   VerticalOptions="Center"/>
                                            <Border Grid.Column="1"
                                                    BackgroundColor="#E3F2FD"
                                                    StrokeShape="RoundRectangle 8"
                                                    Padding="6,2">
                                                <Label Text="RESCHEDULE" FontSize="10"
                                                       TextColor="#1565C0"
                                                       FontAttributes="Bold"/>
                                            </Border>
                                        </Grid>

                                        <Label Text="{Binding Service}"
                                               FontSize="13" TextColor="#1565C0"/>
                                        <Label Text="{Binding AppointmentDate, StringFormat='Original: {0:MMM dd, yyyy  h:mm tt}'}"
                                               FontSize="12" TextColor="Gray"/>
                                        <Label Text="{Binding Phone}"
                                               FontSize="12" TextColor="Gray"/>
                                        <Label Text="Dentist will contact patient for new schedule"
                                               FontSize="11" TextColor="#1565C0"
                                               FontAttributes="Italic"/>

                                        <!-- Move back to pending if needed -->
                                        <Button Text="↩  Move to Pending"
                                                BackgroundColor="#E65100"
                                                TextColor="White"
                                                CornerRadius="8"
                                                FontSize="13"
                                                HeightRequest="38"
                                                HorizontalOptions="Start"
                                                Margin="0,8,0,0"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AppointmentViewModel}}, Path=MoveToPendingCommand}"
                                                CommandParameter="{Binding .}"/>

                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <BoxView HeightRequest="40" Color="Transparent"/>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>