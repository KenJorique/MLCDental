<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ClinicApp.ViewModels.ServicesRelatedVM"
             x:Class="ClinicApp.Views.ServicesRelated.ServiceListPage"
             Title="Services"
             Shell.TabBarIsVisible="False">

	<Grid>

		<ScrollView>
			<VerticalStackLayout Padding="10" Spacing="5">

				<CollectionView ItemsSource="{Binding ServiceCards}">
					<CollectionView.ItemTemplate>
						<DataTemplate x:DataType="vm:ServiceCardViewModel">

							<SwipeView SwipeStarted="OnSwipeStarted">
								<SwipeView.RightItems>
									<SwipeItems>
										<SwipeItem Text="Edit"
                                                   BackgroundColor="RoyalBlue"
                                                   Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                             Path=BindingContext.EditServiceCommand}"
                                                   CommandParameter="{Binding .}" />
										<SwipeItem Text="Delete"
                                                   BackgroundColor="Crimson"
                                                   Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                             Path=BindingContext.DeleteServiceCommand}"
                                                   CommandParameter="{Binding .}" />
									</SwipeItems>
								</SwipeView.RightItems>

								<Frame Margin="5" Padding="15">
									<Frame.GestureRecognizers>
										<TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                      Path=BindingContext.ToggleServiceCardCommand}"
                                            CommandParameter="{Binding .}" />
									</Frame.GestureRecognizers>

									<VerticalStackLayout Spacing="8">
										<Grid ColumnDefinitions="*,Auto">
											<Label Grid.Column="0"
                                                   Text="{Binding Service.ServiceName}"
                                                   FontAttributes="Bold"
                                                   FontSize="16"
                                                   VerticalOptions="Center"/>
											<Label Grid.Column="1"
                                                   Text="{Binding Service.Price, StringFormat='₱{0:N2}'}"
                                                   FontAttributes="Bold"
                                                   FontSize="16"
                                                   TextColor="MediumPurple"
                                                   VerticalOptions="Center"/>
										</Grid>

										<VerticalStackLayout IsVisible="{Binding IsExpanded}" Spacing="6">
											<BoxView HeightRequest="1" Color="LightGray" Margin="0,2"/>
											<Label Text="Description:"
                                                   FontAttributes="Bold"
                                                   FontSize="14"
                                                   TextColor="Gray"/>
											<Label Text="{Binding Service.Description}"
                                                   FontSize="15"/>
										</VerticalStackLayout>
									</VerticalStackLayout>
								</Frame>

							</SwipeView>

						</DataTemplate>
					</CollectionView.ItemTemplate>
				</CollectionView>

			</VerticalStackLayout>
		</ScrollView>

		<Button Text="+ Add Service"
                Command="{Binding GoToAddServiceCommand}"
                VerticalOptions="End"
                HorizontalOptions="End"
                Margin="0,0,20,20"
                CornerRadius="30"
                Padding="20,12" />

	</Grid>
</ContentPage>
