<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ClinicApp.Views.ServicesRelated.ServiceListPage"
             Title="Service &amp; Pricing"
             Shell.TabBarIsVisible="False">

    <Grid>

        <CollectionView ItemsSource="{Binding Services}" Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="5" Padding="10">
                        <HorizontalStackLayout Spacing="15" VerticalOptions="Center">

                            <!-- Service Info -->
                            <VerticalStackLayout WidthRequest="150">
                                <Label Text="{Binding ServiceName}" FontAttributes="Bold" FontSize="16"/>
                                <Label Text="{Binding Price, StringFormat='₱{0:N2}'}" TextColor="Gray"/>
                            </VerticalStackLayout>

                            <!-- Action Buttons -->
                            <HorizontalStackLayout Spacing="10">
                                <Button Text="Edit"
                                    BackgroundColor="RoyalBlue"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.UpdateServiceCommand}"
                                    CommandParameter="{Binding .}" />

                                <Button Text="Delete"
                                    BackgroundColor="Crimson"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteServiceCommand}"
                                    CommandParameter="{Binding .}" />
                            </HorizontalStackLayout>

                        </HorizontalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Floating Add Button (bottom right) -->
        <Button Text="+ Add Service"
                Command="{Binding GoToAddServiceCommand}"
                VerticalOptions="End"
                HorizontalOptions="End"
                Margin="0,0,20,20"
                CornerRadius="30"
                Padding="20,12" />

    </Grid>
</ContentPage>
