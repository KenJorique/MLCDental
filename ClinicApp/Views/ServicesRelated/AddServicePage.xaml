<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ClinicApp.Views.ServicesRelated.AddServicePage"
             Title="{Binding PageTitle}"
             Shell.TabBarIsVisible="False">

	<Grid RowDefinitions="*,Auto">

		<ScrollView Grid.Row="0">
			<VerticalStackLayout Padding="20" Spacing="12">

				<Label Text="Service Name" FontAttributes="Bold"/>
				<Entry Placeholder="Enter service name"
                       Text="{Binding ServiceName}" />

				<Label Text="Price" FontAttributes="Bold"/>
				<Grid ColumnDefinitions="Auto,*">
					<Label Grid.Column="0" Text="₱"
                           VerticalOptions="Center" Margin="0,0,8,0" FontSize="16"/>
					<Entry Grid.Column="1"
                           Placeholder="0.00"
                           Text="{Binding ServicePrice}"
                           Keyboard="Numeric" />
				</Grid>

				<Label Text="Description" FontAttributes="Bold"/>
				<Editor Placeholder="Enter description"
                        Text="{Binding ServiceDescription}"
                        HeightRequest="100" />

			</VerticalStackLayout>
		</ScrollView>

		<Grid Grid.Row="1" ColumnDefinitions="*,*" Padding="16,10" ColumnSpacing="12"
              BackgroundColor="White">
			<Button Grid.Column="0" Text="Cancel"
                    Command="{Binding CancelCommand}"
                    BackgroundColor="LightGray" TextColor="Black"/>
			<Button Grid.Column="1" Text="Save"
                    Command="{Binding SaveCommand}"/>
		</Grid>

	</Grid>
</ContentPage>
