<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ClinicApp.Views.ServicePage"
             Title="ServicePage">
    <VerticalStackLayout Padding="20" Spacing="10">

        <Entry Placeholder="Service Name"
           Text="{Binding ServiceName}" />

        <!-- Restrict keyboard to numbers -->
        <Entry Placeholder="Price"
           Text="{Binding Price}" 
           Keyboard="Numeric"/>

        <Editor Placeholder="Description"
            Text="{Binding Description}" 
            HeightRequest="100"/>

        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
            <Button Text="Add Service"
                Command="{Binding AddServiceCommand}" />
            <Button Text="Update"
                Grid.Column="1"
                Command="{Binding UpdateServiceCommand}" />
        </Grid>

        <Label Text="Available Services" FontAttributes="Bold" Margin="0,10,0,0"/>

        <CollectionView ItemsSource="{Binding Services}"
                    HeightRequest="300"
                    SelectionMode="Single"
                    SelectedItem="{Binding SelectedService}">
            <!-- Your existing ItemTemplate here -->
        </CollectionView>

       

    </VerticalStackLayout>
</ContentPage>