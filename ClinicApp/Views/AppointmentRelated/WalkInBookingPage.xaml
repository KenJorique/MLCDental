<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ClinicApp.ViewModels"
             x:Class="ClinicApp.Views.WalkInBookingPage"
             Title="Walk-in Booking"
             BackgroundColor="#F5F5F5">

    <ContentPage.Content>
        <Grid>
            <ScrollView>
                <VerticalStackLayout Padding="16" Spacing="14">

                    <!-- Header -->
                    <Frame BackgroundColor="#4A4A8A"
                           BorderColor="#4A4A8A"
                           CornerRadius="12" Padding="14"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="🚶 Walk-in Booking"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="White"/>
                            <Label Text="Auto-approved — skips pending queue"
                                   FontSize="11" TextColor="#B0B0D0"/>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Patient lookup -->
                    <Frame BackgroundColor="White"
                           BorderColor="#E0E0E0"
                           CornerRadius="12" Padding="14"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="12">

                            <Label Text="Patient Information"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="#222"/>

                            <!-- Phone + search -->
                            <Label Text="Mobile Number"
                                   FontSize="12" TextColor="#666"/>
                            <Grid ColumnDefinitions="*,80"
                                  ColumnSpacing="8">
                                <Entry Grid.Column="0"
                                       Text="{Binding Phone}"
                                       Placeholder="09XXXXXXXXX"
                                       Keyboard="Telephone"
                                       MaxLength="11"
                                       TextColor="#222"
                                       PlaceholderColor="#AAAAAA"
                                       ReturnType="Search"
                                       ReturnCommand="{Binding LookupPatientCommand}"/>
                                <Button Grid.Column="1"
                                        Text="Search"
                                        BackgroundColor="#4A4A8A"
                                        TextColor="White"
                                        CornerRadius="8"
                                        FontSize="12"
                                        HeightRequest="44"
                                        Command="{Binding LookupPatientCommand}"/>
                            </Grid>

                            <Label Text="{Binding PhoneErrorMsg}"
                                   FontSize="11" TextColor="#C62828"
                                   IsVisible="{Binding HasPhoneError}"/>

                            <!-- Existing patient banner -->
                            <Frame BackgroundColor="#E8F5E9"
                                   BorderColor="#A5D6A7"
                                   CornerRadius="8" Padding="10"
                                   HasShadow="False"
                                   IsVisible="{Binding IsExistingPatient}">
                                <HorizontalStackLayout Spacing="10">
                                    <Label Text="✓"
                                           FontSize="18"
                                           TextColor="#2E7D32"
                                           VerticalOptions="Center"/>
                                    <VerticalStackLayout
                                        VerticalOptions="Center"
                                        Spacing="2">
                                        <Label Text="Existing patient found"
                                               FontSize="11"
                                               TextColor="#388E3C"
                                               FontAttributes="Bold"/>
                                        <Label Text="{Binding FullName}"
                                               FontSize="14"
                                               TextColor="#1B5E20"
                                               FontAttributes="Bold"/>
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                            </Frame>

                            <!-- New patient banner -->
                            <Frame BackgroundColor="#E3F2FD"
                                   BorderColor="#90CAF9"
                                   CornerRadius="8" Padding="10"
                                   HasShadow="False"
                                   IsVisible="{Binding IsNewPatient}">
                                <Label Text="🆕  New patient — fill in details below"
                                       FontSize="12"
                                       TextColor="#1565C0"/>
                            </Frame>

                            <!-- Full name -->
                            <Label Text="Full Name"
                                   FontSize="12" TextColor="#666"/>
                            <Entry Text="{Binding FullName}"
                                   Placeholder="e.g. Juan dela Cruz"
                                   TextColor="#222"
                                   PlaceholderColor="#AAAAAA"
                                   IsReadOnly="{Binding IsExistingPatient}"/>

                            <!-- Email -->
                            <Label Text="Email (optional)"
                                   FontSize="12" TextColor="#666"/>
                            <Entry Text="{Binding Email}"
                                   Placeholder="email@example.com"
                                   Keyboard="Email"
                                   TextColor="#222"
                                   PlaceholderColor="#AAAAAA"
                                   IsReadOnly="{Binding IsExistingPatient}"/>

                        </VerticalStackLayout>
                    </Frame>

                    <!-- Appointment details -->
                    <Frame BackgroundColor="White"
                           BorderColor="#E0E0E0"
                           CornerRadius="12" Padding="14"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="12">

                            <Label Text="Appointment Details"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="#222"/>

                      

                            <!-- Date -->
                            <Label Text="Appointment Date"
                                   FontSize="12" TextColor="#666"/>
                            <DatePicker Date="{Binding AppointmentDate}"
                                        MinimumDate="{Binding MinDate}"
                                        MaximumDate="{Binding MaxDate}"
                                        Format="MMMM dd, yyyy"
                                        TextColor="#222"/>

                            <Frame BackgroundColor="#FCEAEA"
                                   BorderColor="#FFCDD2"
                                   CornerRadius="8" Padding="8"
                                   HasShadow="False"
                                   IsVisible="{Binding IsSunday}">
                                <Label Text="⚠ Clinic is closed on Sundays."
                                       FontSize="12" TextColor="#C62828"/>
                            </Frame>

                            <!-- Time slots -->
                            <Label Text="Select Time Slot"
                                   FontSize="12" TextColor="#666"/>

                            <ActivityIndicator
                                IsRunning="{Binding IsLoadingSlots}"
                                IsVisible="{Binding IsLoadingSlots}"
                                Color="#4A4A8A"
                                HeightRequest="30"/>

                            <Label Text="No available slots for this date"
                                   FontSize="12" TextColor="#888"
                                   IsVisible="{Binding HasNoSlots}"/>

                            <!-- Slot grid using BindableLayout -->
                            <FlexLayout
                                BindableLayout.ItemsSource="{Binding TimeSlots}"
                                Wrap="Wrap"
                                JustifyContent="Start"
                                AlignItems="Start">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="vm:TimeSlotItem">
                                        <Frame Margin="4"
                                               Padding="0"
                                               CornerRadius="8"
                                               HasShadow="False"
                                               BackgroundColor="{Binding BackgroundColor}"
                                               BorderColor="{Binding BorderColor}"
                                               WidthRequest="96"
                                               HeightRequest="56">
                                            <Frame.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                              Path=BindingContext.SelectSlotCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Frame.GestureRecognizers>
                                            <VerticalStackLayout
                                                VerticalOptions="Center"
                                                HorizontalOptions="Center"
                                                Spacing="2">
                                                <Label Text="{Binding Display}"
                                                       FontSize="13"
                                                       FontAttributes="Bold"
                                                       TextColor="{Binding TextColor}"
                                                       HorizontalOptions="Center"/>
                                                <Label Text="{Binding StatusText}"
                                                       FontSize="9"
                                                       TextColor="{Binding StatusColor}"
                                                       HorizontalOptions="Center"/>
                                            </VerticalStackLayout>
                                        </Frame>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>

                            <!-- Selected slot display -->
                            <Label FontSize="12" TextColor="#4A4A8A"
                                   FontAttributes="Bold"
                                   IsVisible="{Binding SelectedSlotDisplay,
                                       Converter={StaticResource StringNotEmptyConverter}}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="Selected: "/>
                                        <Span Text="{Binding SelectedSlotDisplay}"
                                              FontAttributes="Bold"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <!-- Notes -->
                            <Label Text="Notes (optional)"
                                   FontSize="12" TextColor="#666"/>
                            <Editor Text="{Binding Notes}"
                                    Placeholder="Any notes or concerns..."
                                    HeightRequest="80"
                                    FontSize="13"
                                    TextColor="#222"
                                    PlaceholderColor="#AAAAAA"/>

                        </VerticalStackLayout>
                    </Frame>

                    <!-- Summary -->
                    <Frame BackgroundColor="#E8F5E9"
                           BorderColor="#C8E6C9"
                           CornerRadius="12" Padding="14"
                           HasShadow="False"
                           IsVisible="{Binding HasSummary}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="📋 Booking Summary"
                                   FontSize="12" FontAttributes="Bold"
                                   TextColor="#2E7D32"/>
                            <Label Text="{Binding SummaryText}"
                                   FontSize="13" TextColor="#1B5E20"
                                   LineHeight="1.6"/>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Error -->
                    <Frame BackgroundColor="#FCEAEA"
                           BorderColor="#FFCDD2"
                           CornerRadius="12" Padding="14"
                           HasShadow="False"
                           IsVisible="{Binding HasError}">
                        <Label Text="{Binding ErrorMessage}"
                               FontSize="12" TextColor="#C62828"/>
                    </Frame>

                    <!-- Confirm button -->
                    <Button Text="✓  Confirm Walk-in Booking"
                            BackgroundColor="{Binding CanConfirm,
                                Converter={StaticResource BoolToColorConverter},
                                ConverterParameter='#4A4A8A|#BBBBBB'}"
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="52"
                            FontSize="15"
                            FontAttributes="Bold"
                            IsEnabled="{Binding CanConfirm}"
                            Command="{Binding ConfirmBookingCommand}"/>

                    <Button Text="Cancel"
                            BackgroundColor="Transparent"
                            BorderColor="#E0E0E0"
                            BorderWidth="1"
                            TextColor="#888"
                            CornerRadius="12"
                            HeightRequest="44"
                            FontSize="13"
                            Command="{Binding CancelCommand}"/>

                    <BoxView HeightRequest="40" Color="Transparent"/>

                </VerticalStackLayout>
            </ScrollView>

            <!-- Loading overlay -->
            <Grid IsVisible="{Binding IsBusy}"
                  BackgroundColor="#80000000"
                  ZIndex="10">
                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="12">
                    <ActivityIndicator IsRunning="True"
                                       Color="White"
                                       WidthRequest="40"
                                       HeightRequest="40"/>
                    <Label Text="Saving booking..."
                           TextColor="White"
                           FontSize="14"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>

        </Grid>
    </ContentPage.Content>

</ContentPage>