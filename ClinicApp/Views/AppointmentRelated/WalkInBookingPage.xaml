<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ClinicApp.ViewModels"
             x:Class="ClinicApp.Views.WalkInBookingPage"
             Title="Walk-in Booking"
             Shell.NavBarIsVisible="True"
             Shell.BackgroundColor="{StaticResource PrimaryGreen}"
             Shell.TitleColor="White"
             Shell.ForegroundColor="White"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{StaticResource PageBg}">

	<ScrollView>
		<VerticalStackLayout Padding="16" Spacing="0">

			<!-- ── Header banner ── -->
			<Border BackgroundColor="{StaticResource PrimaryGreen}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 12"
                    Padding="14,12"
                    Margin="0,0,0,16">
				<VerticalStackLayout Spacing="2">
					<Label Text="Walk-in Booking"
                           FontSize="15" FontAttributes="Bold"
                           TextColor="White"/>
					<Label Text="Auto-approved — skips pending queue"
                           FontSize="11" TextColor="{StaticResource MediumGreen}"/>
				</VerticalStackLayout>
			</Border>

			<!-- ═══════════════════════════════
                 PATIENT INFORMATION
            ═══════════════════════════════════ -->
			<Border BackgroundColor="White"
                    Stroke="{StaticResource BorderColor}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    Padding="16"
                    Margin="0,0,0,14">
				<VerticalStackLayout Spacing="0">

					<Label Text="Patient Information"
                           FontSize="17" FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryGreen}"
                           Margin="0,0,0,8"/>

					<!-- Full Name -->
					<Label Text="Full Name" Style="{StaticResource FormFieldLabel}"
                           Margin="0,4,0,4"/>
					<Border Style="{StaticResource FormInputBox}">
						<Entry Style="{StaticResource FormEntry}"
                               Text="{Binding SearchName}"/>
					</Border>

					<!-- Live dropdown results -->
					<Border IsVisible="{Binding HasSearchResults}"
                            BackgroundColor="White"
                            Stroke="{StaticResource BorderColor}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            Margin="0,2,0,0">
						<CollectionView ItemsSource="{Binding SearchResults}"
                                        SelectionMode="None"
                                        MaximumHeightRequest="200">
							<CollectionView.ItemTemplate>
								<DataTemplate>
									<Grid Padding="14,10" ColumnDefinitions="*,Auto">
										<Grid.GestureRecognizers>
											<TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                          Path=BindingContext.SelectPatientCommand}"
                                                CommandParameter="{Binding .}"/>
										</Grid.GestureRecognizers>
										<VerticalStackLayout Grid.Column="0" Spacing="2">
											<Label Text="{Binding DisplayName}"
                                                   FontSize="14" FontAttributes="Bold"
                                                   TextColor="{StaticResource TextPrimary}"/>
											<Label Text="{Binding ContactNo}"
                                                   FontSize="12"
                                                   TextColor="{StaticResource TextMuted}"/>
										</VerticalStackLayout>
										<Label Grid.Column="1" Text="Existing"
                                               FontSize="11"
                                               TextColor="{StaticResource PrimaryGreen}"
                                               FontAttributes="Bold"
                                               VerticalOptions="Center"/>
									</Grid>
								</DataTemplate>
							</CollectionView.ItemTemplate>
						</CollectionView>
					</Border>

					<!-- New patient hint -->
					<Border BackgroundColor="#E3F2FD"
                            Stroke="#90CAF9"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8"
                            Padding="12,10"
                            Margin="0,8,0,0"
                            IsVisible="{Binding IsNewPatient}">
						<Label Text="New patient — fill in details below"
                               FontSize="12" TextColor="#1565C0"/>
					</Border>

					<!-- Contact No -->
					<Label Text="Contact No." Style="{StaticResource FormFieldLabel}"
                           Margin="0,12,0,4"/>
					<Border Style="{StaticResource FormInputBox}">
						<Entry Style="{StaticResource FormEntry}"
                               Text="{Binding Phone}"
                               Keyboard="Telephone"
                               MaxLength="11"/>
					</Border>
					<Label Style="{StaticResource FormErrorLabel}"
                           Text="{Binding PhoneErrorMsg}"
                           IsVisible="{Binding HasPhoneError}"
                           Margin="0,4,0,0"/>

					<!-- Email -->
					<Label Text="Email (optional)" Style="{StaticResource FormFieldLabel}"
                           Margin="0,12,0,4"/>
					<Border Style="{StaticResource FormInputBox}">
						<Entry Style="{StaticResource FormEntry}"
                               Text="{Binding Email}"
                               Keyboard="Email"/>
					</Border>

				</VerticalStackLayout>
			</Border>

			<!-- ═══════════════════════════════
                 APPOINTMENT DETAILS
            ═══════════════════════════════════ -->
			<Border BackgroundColor="White"
                    Stroke="{StaticResource BorderColor}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    Padding="16"
                    Margin="0,0,0,14">
				<VerticalStackLayout Spacing="0">

					<Label Text="Appointment Details"
                           FontSize="17" FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryGreen}"
                           Margin="0,0,0,8"/>

					<!-- Date -->
					<Label Text="Appointment Date" Style="{StaticResource FormFieldLabel}"
                           Margin="0,4,0,4"/>
					<Border Style="{StaticResource FormInputBox}">
						<DatePicker Date="{Binding AppointmentDate}"
                                    MinimumDate="{Binding MinDate}"
                                    MaximumDate="{Binding MaxDate}"
                                    Format="MMMM dd, yyyy"
                                    TextColor="{StaticResource TextPrimary}"/>
					</Border>

					<!-- Sunday warning -->
					<Border BackgroundColor="#FCEAEA"
                            Stroke="#FFCDD2"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8"
                            Padding="10,8"
                            Margin="0,8,0,0"
                            IsVisible="{Binding IsSunday}">
						<Label Text="⚠ Clinic is closed on Sundays."
                               FontSize="12" TextColor="#C62828"/>
					</Border>

					<!-- Time slots -->
					<Label Text="Select Time Slot" Style="{StaticResource FormFieldLabel}"
                           Margin="0,12,0,8"/>

					<ActivityIndicator IsRunning="{Binding IsLoadingSlots}"
                                       IsVisible="{Binding IsLoadingSlots}"
                                       Color="{StaticResource PrimaryGreen}"
                                       HeightRequest="30"/>

					<!-- Slots rendered via CollectionView with 3-column layout -->
					<CollectionView ItemsSource="{Binding TimeSlots}"
                                    SelectionMode="None"
                                    IsVisible="{Binding IsLoadingSlots,
                                        Converter={StaticResource InvertedBoolConverter}}">
						<CollectionView.ItemsLayout>
							<GridItemsLayout Orientation="Vertical"
                                             Span="3"
                                             HorizontalItemSpacing="8"
                                             VerticalItemSpacing="8"/>
						</CollectionView.ItemsLayout>
						<CollectionView.ItemTemplate>
							<DataTemplate x:DataType="vm:TimeSlotItem">
								<Border BackgroundColor="{Binding BackgroundColor}"
                                        Stroke="{Binding BorderColor}"
                                        StrokeThickness="1.5"
                                        StrokeShape="RoundRectangle 10"
                                        HeightRequest="56"
                                        Margin="0">
									<Border.GestureRecognizers>
										<TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                      Path=BindingContext.SelectSlotCommand}"
                                            CommandParameter="{Binding .}"/>
									</Border.GestureRecognizers>
									<Label Text="{Binding Display}"
                                           FontSize="13" FontAttributes="Bold"
                                           TextColor="{Binding TextColor}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
								</Border>
							</DataTemplate>
						</CollectionView.ItemTemplate>
					</CollectionView>

					<!-- Notes -->
					<Label Text="Notes (optional)" Style="{StaticResource FormFieldLabel}"
                           Margin="0,12,0,4"/>
					<Border Style="{StaticResource FormInputBoxTall}">
						<Editor Style="{StaticResource FormEditor}"
                                Text="{Binding Notes}"
                                HeightRequest="80"/>
					</Border>

				</VerticalStackLayout>
			</Border>

			<!-- ── Booking Summary ── -->
			<Border BackgroundColor="#E8F5E9"
                    Stroke="#C8E6C9"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    Padding="14"
                    Margin="0,0,0,14"
                    IsVisible="{Binding HasSummary}">
				<VerticalStackLayout Spacing="6">
					<Label Text="Booking Summary"
                           FontSize="14" FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryGreen}"/>
					<Label Text="{Binding SummaryText}"
                           FontSize="14" TextColor="Black"
                           LineHeight="1.6"/>
				</VerticalStackLayout>
			</Border>

			<!-- ── Error ── -->
			<Border BackgroundColor="#FCEAEA"
                    Stroke="#FFCDD2"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    Padding="14"
                    Margin="0,0,0,14"
                    IsVisible="{Binding HasError}">
				<Label Text="{Binding ErrorMessage}"
                       FontSize="13" TextColor="#C62828"/>
			</Border>

			<!-- ── Confirm button ── -->
			<Button Text="Confirm Booking"
                    BackgroundColor="{StaticResource PrimaryGreen}"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="14"
                    HeightRequest="52"
                    HorizontalOptions="Fill"
                    Command="{Binding ConfirmBookingCommand}"
                    Margin="0,0,0,10"/>

		</VerticalStackLayout>
	</ScrollView>

	<!-- Loading overlay -->
	<ContentPage.Content>
	</ContentPage.Content>

</ContentPage>
