<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ClinicApp.ViewModels.UsersRelated"
             x:Class="ClinicApp.Views.UsersRelated.UserListPage"
             Title="Clinic Staff"
             Shell.TabBarIsVisible="False">

    <Grid>

        <CollectionView ItemsSource="{Binding Users}" Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:UserCardViewModel">

                    <!-- SwipeView: swipe left to reveal Edit then Delete -->
                    <SwipeView SwipeStarted="OnSwipeStarted">
                        <SwipeView.RightItems>
                            <SwipeItems>

                                <!-- Edit is first (left of swipe reveal) -->
                                <SwipeItem Text="Edit"
                                           BackgroundColor="RoyalBlue"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                     Path=BindingContext.EditUserCommand}"
                                           CommandParameter="{Binding .}" />

                                <!-- Delete is second (right of swipe reveal) -->
                                <SwipeItem Text="Delete"
                                           BackgroundColor="Crimson"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                     Path=BindingContext.DeleteUserCommand}"
                                           CommandParameter="{Binding .}" />

                            </SwipeItems>
                        </SwipeView.RightItems>

                        <!-- Card content -->
                        <Frame Margin="5" Padding="15" HasShadow="True">
                            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">

                                <!-- Left: Full name and role -->
                                <VerticalStackLayout Grid.Column="0" Spacing="3">
                                    <Label Text="{Binding User.FullName}"
                                           FontAttributes="Bold"
                                           FontSize="16"/>
                                    <Label Text="{Binding User.Role}"
                                           TextColor="Gray"
                                           FontSize="13"/>
                                </VerticalStackLayout>

                                <!-- Right: colored dot + Active/Inactive label -->
                                <HorizontalStackLayout Grid.Column="1"
                                                       Spacing="6"
                                                       VerticalOptions="Center">

                                    <!-- Colored circle indicator: green = Active, red = Inactive -->
                                    <Ellipse WidthRequest="10"
                                             HeightRequest="10"
                                             Fill="{Binding StatusColor}"
                                             VerticalOptions="Center"/>

                                    <Label Text="{Binding StatusText}"
                                           FontSize="13"
                                           VerticalOptions="Center"/>

                                </HorizontalStackLayout>

                            </Grid>
                        </Frame>

                    </SwipeView>

                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Floating Add Staff button (bottom right) -->
        <Button Text="+ Add Staff"
                Command="{Binding GoToAddUserCommand}"
                VerticalOptions="End"
                HorizontalOptions="End"
                Margin="0,0,20,20"
                CornerRadius="30"
                Padding="20,12" />

    </Grid>
</ContentPage>
