<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ClinicApp.Models"
             x:Class="ClinicApp.Views.UsersRelated.UserListPage"
             Title="Clinic Staff">

    <Grid RowDefinitions="Auto, *">
        <Button Text="Add New Staff" 
                Command="{Binding GoToAddUserCommand}" 
                Margin="20"/>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Users}" Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:User">
                    <Frame Margin="5" Padding="15" HasShadow="True">
                        <HorizontalStackLayout Spacing="15" VerticalOptions="Center">

                            <!-- Avatar Placeholder -->
                          

                            <VerticalStackLayout WidthRequest="180">
                                <Label Text="{Binding FullName}" FontAttributes="Bold" FontSize="16"/>
                                <Label Text="{Binding Role}" TextColor="Gray" FontSize="12"/>
                            </VerticalStackLayout>

                            <!-- Actions -->
                            <HorizontalStackLayout Spacing="5">
                                <Button Text="Edit" Scale="0.8" Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditUserCommand}" CommandParameter="{Binding .}"/>
                                <Button Text="Delete" Scale="0.8" BackgroundColor="Crimson" Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteUserCommand}" CommandParameter="{Binding .}"/>
                            </HorizontalStackLayout>

                        </HorizontalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>