<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:ClinicApp.ViewModels.DentalChart"
    x:Class="ClinicApp.Views.DentalChart.DentalChartPage"
    x:DataType="vm:DentalChartViewModel"
    Title="Dental Chart"
    Shell.TabBarIsVisible="False"
    BackgroundColor="#F0F4F8">

    <Grid>
        <!-- ── Main scrollable content ── -->
        <ScrollView>
            <VerticalStackLayout Padding="12,10,12,30" Spacing="0">

                <!-- ── Patient header ── -->
                <Frame BackgroundColor="White" CornerRadius="12"
                       HasShadow="True" Padding="16,12" Margin="0,0,0,12">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="{Binding PatientName}"
                                   FontSize="20" FontAttributes="Bold" TextColor="#1A2B4A"/>
                            <Label Text="{Binding PatientId, StringFormat='Patient ID: {0}'}"
                                   FontSize="12" TextColor="#6B7A9A"/>
                        </VerticalStackLayout>
                        <ActivityIndicator Grid.Column="1"
                                           IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           Color="#2563EB"
                                           WidthRequest="26" HeightRequest="26"
                                           VerticalOptions="Center"/>
                    </Grid>
                </Frame>

                <!-- ── Chart card ── -->
                <Frame BackgroundColor="White" CornerRadius="14"
                       HasShadow="True" Padding="15,15" Margin="0,0,0,15">
                    <VerticalStackLayout Spacing="4">

                        <!-- Header row -->
                        <Grid ColumnDefinitions="*,Auto,*" Margin="4,0,4,6">
                            <Label Grid.Column="0" Text="RIGHT" FontSize="11"
                                   TextColor="#9CA3AF" HorizontalTextAlignment="Start"
                                   VerticalTextAlignment="Center"/>
                            <Label Grid.Column="1" Text="DENTAL CHART"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="#1A2B4A" HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="2" Text="LEFT" FontSize="11"
                                   TextColor="#9CA3AF" HorizontalTextAlignment="End"
                                   VerticalTextAlignment="Center"/>
                        </Grid>

                        <!-- UPPER arch label -->
                        <Label Text="UPPER ARCH" FontSize="10" FontAttributes="Bold"
                               TextColor="#6B7A9A" HorizontalTextAlignment="Center"
                               Margin="0,2,0,4"/>

                        <!-- Upper teeth 1–16 — horizontal scroll on mobile -->
                        <ScrollView Orientation="Horizontal"
                                    HorizontalScrollBarVisibility="Never">
                            <FlexLayout Direction="Row" JustifyContent="Start"
                                        AlignItems="Center" Wrap="NoWrap"
                                        BindableLayout.ItemsSource="{Binding UpperTeeth}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ToothViewModel">
                                        <Grid WidthRequest="42" HeightRequest="54" Margin="1,0">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                              Path=BindingContext.ToothTappedCommand}"
                                                    CommandParameter="{Binding ToothNumber}"/>
                                            </Grid.GestureRecognizers>

                                            <!-- Selection ring -->
                                            <Border IsVisible="{Binding IsSelected}"
                                                    StrokeThickness="2.5"
                                                    Stroke="#FFA500"
                                                    BackgroundColor="Transparent"
                                                    ZIndex="2">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="6"/>
                                                </Border.StrokeShape>
                                            </Border>

                                            <!-- Tooth body -->
                                            <Border BackgroundColor="{Binding ToothColor}"
                                                    StrokeThickness="1" Stroke="#CCCCCC">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="5"/>
                                                </Border.StrokeShape>
                                                <VerticalStackLayout Padding="2" Spacing="1">
                                                    <Label Text="{Binding ToothLabel}"
                                                           Margin="0,10,0,0"
                                                           FontSize="10" FontAttributes="Bold"
                                                           HorizontalTextAlignment="Center"
                                                           TextColor="#333333"/>
                                                    <Label Text="T" FontSize="16"
                                                           TextColor="Black"
                                                           HorizontalTextAlignment="Center"
                                                           VerticalTextAlignment="Center"
                                                           IsVisible="{Binding Condition,
                                                               Converter={StaticResource StringEqualConverter},
                                                               ConverterParameter=Normal}"/>
                                                    <BoxView
                                                        WidthRequest="24" HeightRequest="20"
                                                        CornerRadius="3"
                                                        Color="{Binding ToothColor}"
                                                        HorizontalOptions="Center"
                                                        IsVisible="{Binding Condition,
                                                            Converter={StaticResource StringNotEqualConverter},
                                                            ConverterParameter=Normal}"/>
                                                </VerticalStackLayout>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>
                        </ScrollView>

                        <!-- Gum divider -->
                        <Grid HeightRequest="22" Margin="0,6">
                            <BoxView HeightRequest="1" BackgroundColor="#E2E8F0"
                                     VerticalOptions="Center"/>
                            <Frame BackgroundColor="White" Padding="10,2"
                                   CornerRadius="8" HasShadow="False"
                                   HorizontalOptions="Center" VerticalOptions="Center"
                                   BorderColor="#E2E8F0">
                                <Label Text="— gum line —" FontSize="9"
                                       TextColor="Black" HorizontalTextAlignment="Center"/>
                            </Frame>
                        </Grid>

                        <!-- Lower teeth 17–32 — horizontal scroll on mobile -->
                        <ScrollView Orientation="Horizontal"
                                    HorizontalScrollBarVisibility="Never">
                            <FlexLayout Direction="Row" JustifyContent="Start"
                                        AlignItems="Center" Wrap="NoWrap"
                                        BindableLayout.ItemsSource="{Binding LowerTeeth}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ToothViewModel">
                                        <Grid WidthRequest="42" HeightRequest="54" Margin="1,0">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                              Path=BindingContext.ToothTappedCommand}"
                                                    CommandParameter="{Binding ToothNumber}"/>
                                            </Grid.GestureRecognizers>

                                            <!-- Selection ring -->
                                            <Border IsVisible="{Binding IsSelected}"
                                                    StrokeThickness="2.5"
                                                    Stroke="Gray"
                                                    BackgroundColor="Transparent"
                                                    ZIndex="2">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="6"/>
                                                </Border.StrokeShape>
                                            </Border>

                                            <!-- Tooth body -->
                                            <Border BackgroundColor="{Binding ToothColor}"
                                                    StrokeThickness="1" Stroke="#CCCCCC">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="5"/>
                                                </Border.StrokeShape>
                                                <VerticalStackLayout Padding="2" Spacing="1">
                                                    <Label Text="{Binding ToothLabel}"
                                                           Margin="0,10,0,0"
                                                           FontSize="10" FontAttributes="Bold"
                                                           HorizontalTextAlignment="Center"
                                                           TextColor="#333333"/>
                                                    <Label Text="T" FontSize="16"
                                                           TextColor="Black"
                                                           HorizontalTextAlignment="Center"
                                                           VerticalTextAlignment="Center"
                                                           IsVisible="{Binding Condition,
                                                               Converter={StaticResource StringEqualConverter},
                                                               ConverterParameter=Normal}"/>
                                                    
                                                    <BoxView
                                                        WidthRequest="24" HeightRequest="20"
                                                        CornerRadius="3"
                                                        Color="{Binding ToothColor}"
                                                        HorizontalOptions="Center"
                                                        IsVisible="{Binding Condition,
                                                            Converter={StaticResource StringNotEqualConverter},
                                                            ConverterParameter=Normal}"/>
                                                </VerticalStackLayout>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>
                        </ScrollView>

                        <!-- LOWER arch label -->
                     
                        <Label Text="LOWER ARCH" FontSize="10" FontAttributes="Bold"
                               TextColor="Black" HorizontalTextAlignment="Center"
                               Margin="0,4,0,2"/>

                    </VerticalStackLayout>
                </Frame>

                <!-- ── Legend card ── -->
                <Frame BackgroundColor="White" CornerRadius="12"
                       HasShadow="True" Padding="16,12" Margin="0,0,0,12">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="LEGEND" FontSize="12" FontAttributes="Bold"
                               TextColor="Black" Margin="0,0,0,4"/>

                        <HorizontalStackLayout Spacing="10">
                            <Ellipse WidthRequest="16" HeightRequest="16" Fill="#FFFFFF"
                                     Stroke="#AAAAAA" StrokeThickness="1"/>
                            <Label Text="Normal / Untreated" FontSize="13" TextColor="#374151" VerticalTextAlignment="Center"/>
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="10">
                            <Ellipse WidthRequest="16" HeightRequest="16" Fill="#0000FF"/>
                            <Label Text="Existing Restoration (Filling)" FontSize="13" TextColor="#374151" VerticalTextAlignment="Center"/>
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="10">
                            <Ellipse WidthRequest="16" HeightRequest="16" Fill="#FF0000"/>
                            <Label Text="Active Decay (Caries)" FontSize="13" TextColor="#374151" VerticalTextAlignment="Center"/>
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="10">
                            <Ellipse WidthRequest="16" HeightRequest="16" Fill="#00FF00"/>
                            <Label Text="Completed Treatment" FontSize="13" TextColor="#374151" VerticalTextAlignment="Center"/>
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="10">
                            <Ellipse WidthRequest="16" HeightRequest="16" Fill="#000000"/>
                            <Label Text="Missing / Extracted" FontSize="13" TextColor="#374151" VerticalTextAlignment="Center"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- ── Status message ── -->
                <Label Text="{Binding StatusMessage}"
                       FontSize="12" TextColor="#64748B"
                       HorizontalTextAlignment="Center"
                       Margin="0,4"
                       IsVisible="{Binding StatusMessage,
                           Converter={StaticResource StringNotEmptyConverter}}"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ═══════════════════════════════════════════════════════════
             TOOTH DETAIL MODAL OVERLAY
             Shown when IsModalVisible = true
        ════════════════════════════════════════════════════════════════ -->
        <Grid IsVisible="{Binding IsModalVisible}"
              BackgroundColor="#80000000"
              ZIndex="10">
            <Grid.GestureRecognizers>
                <!-- Tap backdrop to dismiss -->
                <TapGestureRecognizer Command="{Binding CloseModalCommand}"/>
            </Grid.GestureRecognizers>

            <!-- Modal panel — centered, max 480 wide -->
            <Frame BackgroundColor="White" CornerRadius="18"
                   HasShadow="True" Padding="0"
                   WidthRequest="360"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"
                   Margin="20,0">
                <Frame.GestureRecognizers>
                    <!-- Prevent backdrop tap propagating through panel -->
                    <TapGestureRecognizer/>
                </Frame.GestureRecognizers>

                <VerticalStackLayout Spacing="0">

                    <!-- ── Modal header ── -->
                    <Grid BackgroundColor="Gray"
                          Padding="16,14"
                          ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="{Binding ModalToothTitle}"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="White"/>
                            <Label Text="{Binding ModalToothName}"
                                   FontSize="12" TextColor="#BFDBFE"/>
                        </VerticalStackLayout>
                        <!-- Close × button -->
                        <Button Grid.Column="1"
                                Text="✕"
                                TextColor="White"
                                BackgroundColor="Transparent"
                                FontSize="18"
                                WidthRequest="36" HeightRequest="36"
                                Padding="0"
                                Command="{Binding CloseModalCommand}"/>
                    </Grid>

                    <!-- ── Body ── -->
                    <VerticalStackLayout Padding="16,14" Spacing="12">

                        <!-- Condition badge row + date -->
                        <Grid ColumnDefinitions="*,Auto">
                            <HorizontalStackLayout Grid.Column="0" Spacing="8"
                                                   VerticalOptions="Center">
                                <BoxView WidthRequest="14" HeightRequest="14"
                                         CornerRadius="7"
                                         Color="{Binding ModalConditionColor}"
                                         VerticalOptions="Center"/>
                                <Label Text="{Binding ModalCondition}"
                                       FontSize="14" FontAttributes="Bold"
                                       TextColor="Black"
                                       VerticalTextAlignment="Center"/>
                            </HorizontalStackLayout>
                            <Label Grid.Column="1"
                                   Text="{Binding ModalLastUpdated, StringFormat=' {0}'}"
                                   FontSize="11" TextColor="#6B7A9A"
                                   VerticalTextAlignment="Center"/>
                        </Grid>

                        <!-- Divider -->
                        <BoxView HeightRequest="1" BackgroundColor="#E5E7EB"/>

                        <!-- ── View mode ── -->
                        <VerticalStackLayout IsVisible="{Binding IsEditMode,
                                                         Converter={StaticResource InvertedBoolConverter}}"
                                             Spacing="8">
                            <Label Text="NOTES" FontSize="10" FontAttributes="Bold"
                                   TextColor="#9CA3AF"/>
                            <Label Text="{Binding ModalNotes}"
                                   FontSize="13" TextColor="#374151"
                                   LineBreakMode="WordWrap"/>
                            <Label Text="No notes recorded."
                                   FontSize="13" TextColor="#9CA3AF" FontAttributes="Italic"
                                   IsVisible="{Binding ModalNotes,
                                       Converter={StaticResource StringEmptyConverter}}"/>
                        </VerticalStackLayout>

                        <!-- ── Edit mode ── -->
                        <VerticalStackLayout IsVisible="{Binding IsEditMode}" Spacing="10">

                            <!-- Condition picker -->
                            <Label Text="CONDITION" FontSize="10" FontAttributes="Bold"
                                   TextColor="#9CA3AF"/>
                            <Picker ItemsSource="{Binding ConditionOptions}"
                                    SelectedItem="{Binding EditCondition}"
                                    FontSize="14" TextColor="#1A2B4A"
                                    BackgroundColor="#F1F5F9"/>

                            <!-- Notes editor -->
                            <Label Text="NOTES" FontSize="10" FontAttributes="Bold"
                                   TextColor="#9CA3AF" Margin="0,4,0,0"/>
                            <Editor Text="{Binding EditNotes}"
                                    Placeholder="Add clinical notes…"
                                    PlaceholderColor="#9CA3AF"
                                    FontSize="13"
                                    BackgroundColor="#F8FAFC"
                                    MinimumHeightRequest="80"
                                    AutoSize="TextChanges"/>
                        </VerticalStackLayout>

                        <!-- ── Action buttons ── -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,4,0,0">

                            <!-- View mode: Edit + Clear -->
                            <Button Grid.Column="0"
                                    IsVisible="{Binding IsEditMode,
                                        Converter={StaticResource InvertedBoolConverter}}"
                                    Text="Edit"
                                    BackgroundColor="Gray" TextColor="White"
                                    CornerRadius="8" FontSize="14"
                                    Command="{Binding EnterEditModeCommand}"/>
                            <Button Grid.Column="1"
                                    IsVisible="{Binding IsEditMode,
                                        Converter={StaticResource InvertedBoolConverter}}"
                                    Text="Clear"
                                    BackgroundColor="#FEE2E2" TextColor="Gray"
                                    CornerRadius="8" FontSize="14"
                                    Command="{Binding ClearToothFromModalCommand}"/>

                            <!-- Edit mode: Save + Cancel -->
                            <Button Grid.Column="0"
                                    IsVisible="{Binding IsEditMode}"
                                    Text=" Save"
                                     TextColor="White"
                                    CornerRadius="8" FontSize="14"
                                    Command="{Binding SaveEditCommand}"/>
                            <Button Grid.Column="1"
                                    IsVisible="{Binding IsEditMode}"
                                    Text="Cancel"
                                    BackgroundColor="#F1F5F9" TextColor="#6B7A9A"
                                    CornerRadius="8" FontSize="14"
                                    Command="{Binding CancelEditCommand}"/>
                        </Grid>

                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>
        </Grid>

    </Grid>
</ContentPage>
