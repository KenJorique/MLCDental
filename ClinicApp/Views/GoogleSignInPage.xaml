<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ClinicApp.Views.GoogleSignInPage"
             Title="Google Tasks"
             BackgroundColor="White">

    <VerticalStackLayout Padding="32" Spacing="24"
                         VerticalOptions="Center">

        <Label Text="🗂️" FontSize="48" HorizontalOptions="Center"/>

        <Label Text="Connect Google Tasks"
               FontSize="20" FontAttributes="Bold"
               TextColor="#333" HorizontalOptions="Center"/>

        <Label Text="Approved appointments will automatically appear in your Google Tasks so you never miss a scheduled patient."
               FontSize="13" TextColor="#666"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center"
               LineHeight="1.5"/>

        <Frame BackgroundColor="#F8F9FA" BorderColor="#E0E0E0"
               CornerRadius="12" Padding="16">
            <VerticalStackLayout Spacing="10">
                <Label FontSize="12" TextColor="#444">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="✓  " TextColor="#2E7D32" FontAttributes="Bold"/>
                            <Span Text="Tasks created automatically on approval"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                <Label FontSize="12" TextColor="#444">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="✓  " TextColor="#2E7D32" FontAttributes="Bold"/>
                            <Span Text="Tasks marked complete when appointment done"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
               
            </VerticalStackLayout>
        </Frame>

        <Button x:Name="SignInButton"
                Text="Connect to Google Tasks"
                BackgroundColor="#4285F4"
                TextColor="White"
                CornerRadius="10"
                HeightRequest="50"
                FontSize="14"
                FontAttributes="Bold"
                Clicked="OnSignInClicked"/>

        <Button Text="Skip for now"
                BackgroundColor="Transparent"
                TextColor="#888"
                BorderColor="#E0E0E0"
                BorderWidth="1"
                CornerRadius="10"
                HeightRequest="44"
                FontSize="13"
                Clicked="OnSkipClicked"/>

        <Label x:Name="StatusLabel"
               FontSize="12"
               TextColor="#888"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center"
               IsVisible="False"/>

    </VerticalStackLayout>
</ContentPage>