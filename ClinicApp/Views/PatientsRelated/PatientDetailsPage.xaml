<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ClinicApp.ViewModels.PatientsRelatedVM"
             xmlns:converters="clr-namespace:ClinicApp.Converters"
             x:Class="ClinicApp.Views.PatientsRelated.PatientDetailsPage"
             x:DataType="vm:PatientDetailsViewModel"
             Title="Patient Profile"
             BackgroundColor="{StaticResource PageBg}"
             Shell.TabBarIsVisible="False">

	<Grid RowDefinitions="Auto,Auto,*,Auto">

		<!-- ══ ROW 0: HEADER ══ -->
		<Border Grid.Row="0"
                BackgroundColor="{StaticResource HeaderPink}"
                StrokeThickness="0"
                Padding="16,16,16,20">
			<VerticalStackLayout Spacing="2">
				<Label Text="{Binding FullName}"
                       FontSize="20" FontAttributes="Bold" TextColor="White"/>
				<Label Text="{Binding DateRegistered, StringFormat='Registered {0}'}"
                       FontSize="12" TextColor="White"/>
			</VerticalStackLayout>
		</Border>

		<!-- ══ ROW 1: TABS ══ -->
		<Grid Grid.Row="1" ColumnDefinitions="*,*" BackgroundColor="{StaticResource PageBg}">
			<VerticalStackLayout Grid.Column="0" Spacing="0">
				<VerticalStackLayout.GestureRecognizers>
					<TapGestureRecognizer Command="{Binding SelectPersonalTabCommand}"/>
				</VerticalStackLayout.GestureRecognizers>
				<Label Text="Personal Info" Padding="0,12"
                       HorizontalTextAlignment="Center" FontSize="14"
                       FontAttributes="{Binding IsPersonalTabActive, Converter={StaticResource BoolToFontAttrConverter}}"
                       TextColor="{Binding IsPersonalTabActive, Converter={StaticResource BoolToTabTextConverter}}"/>
				<BoxView HeightRequest="2.5" Color="{StaticResource PrimaryPink}"
                         IsVisible="{Binding IsPersonalTabActive}"/>
				<BoxView HeightRequest="2.5" Color="{StaticResource Divider}"
                         IsVisible="{Binding IsMedicalTabActive}"/>
			</VerticalStackLayout>

			<VerticalStackLayout Grid.Column="1" Spacing="0">
				<VerticalStackLayout.GestureRecognizers>
					<TapGestureRecognizer Command="{Binding SelectMedicalTabCommand}"/>
				</VerticalStackLayout.GestureRecognizers>
				<Label Text="Medical Record" Padding="0,12"
                       HorizontalTextAlignment="Center" FontSize="14"
                       FontAttributes="{Binding IsMedicalTabActive, Converter={StaticResource BoolToFontAttrConverter}}"
                       TextColor="{Binding IsMedicalTabActive, Converter={StaticResource BoolToTabTextConverter}}"/>
				<BoxView HeightRequest="2.5" Color="{StaticResource PrimaryPink}"
                         IsVisible="{Binding IsMedicalTabActive}"/>
				<BoxView HeightRequest="2.5" Color="{StaticResource Divider}"
                         IsVisible="{Binding IsPersonalTabActive}"/>
			</VerticalStackLayout>
		</Grid>

		<!-- ══ ROW 2: CONTENT ══ -->
		<ScrollView Grid.Row="2">
			<VerticalStackLayout Padding="16,16,16,8" Spacing="0">

				<ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource PrimaryPink}"
                                   HorizontalOptions="Center" Margin="0,24"/>

				<!-- ── TAB 1: PERSONAL INFO ── -->
				<VerticalStackLayout IsVisible="{Binding IsPersonalTabActive}" Spacing="0">

					<Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
						<Label Grid.Column="0"
                               Text="{Binding PersonalLastUpdated}"
                               FontSize="12" TextColor="{StaticResource TextMuted}"
                               VerticalOptions="Center"/>
						<Label Grid.Column="1"
                               FontFamily="MaterialSymbolsRounded"
                               Text="&#xe3c9;"
                               FontSize="22"
                               TextColor="{StaticResource PrimaryPink}"
                               VerticalOptions="Center"
                               Padding="8,0,0,0">
							<Label.GestureRecognizers>
								<TapGestureRecognizer Command="{Binding TogglePersonalEditCommand}"/>
							</Label.GestureRecognizers>
						</Label>
					</Grid>

					<!-- Personal Information -->
					<Border Style="{StaticResource CardStyle}">
						<Border.StrokeShape>
							<RoundRectangle CornerRadius="14"/>
						</Border.StrokeShape>
						<VerticalStackLayout Spacing="0">
							<Label Text="PERSONAL INFORMATION" Style="{StaticResource SectionTitleStyle}"/>

							<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
								<Label Grid.Column="0" Text="Gender" Style="{StaticResource RowLabelStyle}"/>
								<Label Grid.Column="1" Text="{Binding Gender}" Style="{StaticResource RowValueStyle}"
                                       IsVisible="{Binding IsPersonalEditMode, Converter={StaticResource InvertedBoolConverter}}"/>
								<Picker Grid.Column="1" ItemsSource="{Binding GenderOptions}"
                                        SelectedItem="{Binding Gender}"
                                        HorizontalTextAlignment="End" FontSize="14"
                                        IsVisible="{Binding IsPersonalEditMode}"/>
							</Grid>
							<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>

							<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
								<Label Grid.Column="0" Text="Date of Birth" Style="{StaticResource RowLabelStyle}"/>
								<Label Grid.Column="1" Text="{Binding DateOfBirthDisplay}" Style="{StaticResource RowValueStyle}"
                                       IsVisible="{Binding IsPersonalEditMode, Converter={StaticResource InvertedBoolConverter}}"/>
								<DatePicker Grid.Column="1" Date="{Binding DateOfBirthDate}"
                                            Format="MMMM dd, yyyy" FontSize="14"
                                            HorizontalOptions="End"
                                            IsVisible="{Binding IsPersonalEditMode}"/>
							</Grid>
							<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>

							<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
								<Label Grid.Column="0" Text="Age" Style="{StaticResource RowLabelStyle}"/>
								<Label Grid.Column="1" Text="{Binding Age, StringFormat='{0} yrs'}" Style="{StaticResource RowValueStyle}"/>
							</Grid>
							<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>

							<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
								<Label Grid.Column="0" Text="Nickname" Style="{StaticResource RowLabelStyle}"/>
								<Label Grid.Column="1" Text="{Binding Nickname}" Style="{StaticResource RowValueStyle}"
                                       IsVisible="{Binding IsPersonalEditMode, Converter={StaticResource InvertedBoolConverter}}"/>
								<Entry Grid.Column="1" Text="{Binding Nickname}"
                                       HorizontalTextAlignment="End" FontSize="14"
                                       MinimumHeightRequest="44" BackgroundColor="Transparent"
                                       IsVisible="{Binding IsPersonalEditMode}"/>
							</Grid>
							<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>

							<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
								<Label Grid.Column="0" Text="Nationality" Style="{StaticResource RowLabelStyle}"/>
								<Label Grid.Column="1" Text="{Binding Nationality}" Style="{StaticResource RowValueStyle}"
                                       IsVisible="{Binding IsPersonalEditMode, Converter={StaticResource InvertedBoolConverter}}"/>
								<Entry Grid.Column="1" Text="{Binding Nationality}"
                                       HorizontalTextAlignment="End" FontSize="14"
                                       MinimumHeightRequest="44" BackgroundColor="Transparent"
                                       IsVisible="{Binding IsPersonalEditMode}"/>
							</Grid>
							<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>

							<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
								<Label Grid.Column="0" Text="Religion" Style="{StaticResource RowLabelStyle}"/>
								<Label Grid.Column="1" Text="{Binding Religion}" Style="{StaticResource RowValueStyle}"
                                       IsVisible="{Binding IsPersonalEditMode, Converter={StaticResource InvertedBoolConverter}}"/>
								<Entry Grid.Column="1" Text="{Binding Religion}"
                                       HorizontalTextAlignment="End" FontSize="14"
                                       MinimumHeightRequest="44" BackgroundColor="Transparent"
                                       IsVisible="{Binding IsPersonalEditMode}"/>
							</Grid>
							<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>

							<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
								<Label Grid.Column="0" Text="Occupation" Style="{StaticResource RowLabelStyle}"/>
								<Label Grid.Column="1" Text="{Binding Occupation}" Style="{StaticResource RowValueStyle}"
                                       IsVisible="{Binding IsPersonalEditMode, Converter={StaticResource InvertedBoolConverter}}"/>
								<Entry Grid.Column="1" Text="{Binding Occupation}"
                                       HorizontalTextAlignment="End" FontSize="14"
                                       MinimumHeightRequest="44" BackgroundColor="Transparent"
                                       IsVisible="{Binding IsPersonalEditMode}"/>
							</Grid>
							<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>

							<Grid ColumnDefinitions="*,*" Margin="0,0,0,0">
								<Label Grid.Column="0" Text="Address" Style="{StaticResource RowLabelStyle}"/>
								<Label Grid.Column="1" Text="{Binding Address}" Style="{StaticResource RowValueStyle}"
                                       IsVisible="{Binding IsPersonalEditMode, Converter={StaticResource InvertedBoolConverter}}"/>
								<Entry Grid.Column="1" Text="{Binding Address}"
                                       HorizontalTextAlignment="End" FontSize="14"
                                       MinimumHeightRequest="44" BackgroundColor="Transparent"
                                       IsVisible="{Binding IsPersonalEditMode}"/>
							</Grid>
						</VerticalStackLayout>
					</Border>

					<!-- Contact Details -->
					<Border Style="{StaticResource CardStyle}">
						<Border.StrokeShape>
							<RoundRectangle CornerRadius="14"/>
						</Border.StrokeShape>
						<VerticalStackLayout Spacing="0">
							<Label Text="CONTACT DETAILS" Style="{StaticResource SectionTitleStyle}"/>

							<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
								<Label Grid.Column="0" Text="Mobile" Style="{StaticResource RowLabelStyle}"/>
								<Label Grid.Column="1" Text="{Binding MobileNo}" Style="{StaticResource RowValueStyle}"
                                       IsVisible="{Binding IsPersonalEditMode, Converter={StaticResource InvertedBoolConverter}}"/>
								<Entry Grid.Column="1" Text="{Binding MobileNo}" Keyboard="Telephone"
                                       HorizontalTextAlignment="End" FontSize="14"
                                       MinimumHeightRequest="44" BackgroundColor="Transparent"
                                       IsVisible="{Binding IsPersonalEditMode}"/>
							</Grid>
							<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>

							<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
								<Label Grid.Column="0" Text="Email" Style="{StaticResource RowLabelStyle}"/>
								<Label Grid.Column="1" Text="{Binding Email}" Style="{StaticResource RowValueStyle}"
                                       IsVisible="{Binding IsPersonalEditMode, Converter={StaticResource InvertedBoolConverter}}"/>
								<Entry Grid.Column="1" Text="{Binding Email}" Keyboard="Email"
                                       HorizontalTextAlignment="End" FontSize="14"
                                       MinimumHeightRequest="44" BackgroundColor="Transparent"
                                       IsVisible="{Binding IsPersonalEditMode}"/>
							</Grid>
							<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>

							<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
								<Label Grid.Column="0" Text="Home" Style="{StaticResource RowLabelStyle}"/>
								<Label Grid.Column="1" Text="{Binding HomeNo}" Style="{StaticResource RowValueStyle}"
                                       IsVisible="{Binding IsPersonalEditMode, Converter={StaticResource InvertedBoolConverter}}"/>
								<Entry Grid.Column="1" Text="{Binding HomeNo}" Keyboard="Telephone"
                                       HorizontalTextAlignment="End" FontSize="14"
                                       MinimumHeightRequest="44" BackgroundColor="Transparent"
                                       IsVisible="{Binding IsPersonalEditMode}"/>
							</Grid>
							<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>

							<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
								<Label Grid.Column="0" Text="Office" Style="{StaticResource RowLabelStyle}"/>
								<Label Grid.Column="1" Text="{Binding OfficeNo}" Style="{StaticResource RowValueStyle}"
                                       IsVisible="{Binding IsPersonalEditMode, Converter={StaticResource InvertedBoolConverter}}"/>
								<Entry Grid.Column="1" Text="{Binding OfficeNo}" Keyboard="Telephone"
                                       HorizontalTextAlignment="End" FontSize="14"
                                       MinimumHeightRequest="44" BackgroundColor="Transparent"
                                       IsVisible="{Binding IsPersonalEditMode}"/>
							</Grid>
							<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>

							<Grid ColumnDefinitions="*,*" Margin="0,0,0,0">
								<Label Grid.Column="0" Text="Fax" Style="{StaticResource RowLabelStyle}"/>
								<Label Grid.Column="1" Text="{Binding FaxNo}" Style="{StaticResource RowValueStyle}"
                                       IsVisible="{Binding IsPersonalEditMode, Converter={StaticResource InvertedBoolConverter}}"/>
								<Entry Grid.Column="1" Text="{Binding FaxNo}"
                                       HorizontalTextAlignment="End" FontSize="14"
                                       MinimumHeightRequest="44" BackgroundColor="Transparent"
                                       IsVisible="{Binding IsPersonalEditMode}"/>
							</Grid>
						</VerticalStackLayout>
					</Border>

					<!-- Guardian -->
					<Border Style="{StaticResource CardStyle}">
						<Border.StrokeShape>
							<RoundRectangle CornerRadius="14"/>
						</Border.StrokeShape>
						<VerticalStackLayout Spacing="0">
							<Label Text="GUARDIAN / EMERGENCY CONTACT" Style="{StaticResource SectionTitleStyle}"/>

							<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
								<Label Grid.Column="0" Text="Name" Style="{StaticResource RowLabelStyle}"/>
								<Label Grid.Column="1" Text="{Binding GuardianName}" Style="{StaticResource RowValueStyle}"
                                       IsVisible="{Binding IsPersonalEditMode, Converter={StaticResource InvertedBoolConverter}}"/>
								<Entry Grid.Column="1" Text="{Binding GuardianName}"
                                       HorizontalTextAlignment="End" FontSize="14"
                                       MinimumHeightRequest="44" BackgroundColor="Transparent"
                                       IsVisible="{Binding IsPersonalEditMode}"/>
							</Grid>
							<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>

							<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
								<Label Grid.Column="0" Text="Relationship" Style="{StaticResource RowLabelStyle}"/>
								<Label Grid.Column="1" Text="{Binding GuardianRelationship}" Style="{StaticResource RowValueStyle}"
                                       IsVisible="{Binding IsPersonalEditMode, Converter={StaticResource InvertedBoolConverter}}"/>
								<Entry Grid.Column="1" Text="{Binding GuardianRelationship}"
                                       HorizontalTextAlignment="End" FontSize="14"
                                       MinimumHeightRequest="44" BackgroundColor="Transparent"
                                       IsVisible="{Binding IsPersonalEditMode}"/>
							</Grid>
							<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>

							<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
								<Label Grid.Column="0" Text="Occupation" Style="{StaticResource RowLabelStyle}"/>
								<Label Grid.Column="1" Text="{Binding GuardianOccupation}" Style="{StaticResource RowValueStyle}"
                                       IsVisible="{Binding IsPersonalEditMode, Converter={StaticResource InvertedBoolConverter}}"/>
								<Entry Grid.Column="1" Text="{Binding GuardianOccupation}"
                                       HorizontalTextAlignment="End" FontSize="14"
                                       MinimumHeightRequest="44" BackgroundColor="Transparent"
                                       IsVisible="{Binding IsPersonalEditMode}"/>
							</Grid>
							<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>

							<Grid ColumnDefinitions="*,*" Margin="0,0,0,0">
								<Label Grid.Column="0" Text="Mobile" Style="{StaticResource RowLabelStyle}"/>
								<Label Grid.Column="1" Text="{Binding GuardianMobile}" Style="{StaticResource RowValueStyle}"
                                       IsVisible="{Binding IsPersonalEditMode, Converter={StaticResource InvertedBoolConverter}}"/>
								<Entry Grid.Column="1" Text="{Binding GuardianMobile}" Keyboard="Telephone"
                                       HorizontalTextAlignment="End" FontSize="14"
                                       MinimumHeightRequest="44" BackgroundColor="Transparent"
                                       IsVisible="{Binding IsPersonalEditMode}"/>
							</Grid>
						</VerticalStackLayout>
					</Border>

				</VerticalStackLayout>

				<!-- ── TAB 2: MEDICAL RECORD ── -->
				<VerticalStackLayout IsVisible="{Binding IsMedicalTabActive}" Spacing="0">

					<Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
						<Label Grid.Column="0"
                               Text="{Binding MedicalLastUpdated}"
                               FontSize="12" TextColor="{StaticResource TextMuted}"
                               VerticalOptions="Center"/>
						<Label Grid.Column="1"
                               FontFamily="MaterialSymbolsRounded"
                               Text="&#xe3c9;"
                               FontSize="22"
                               TextColor="{StaticResource PrimaryPink}"
                               VerticalOptions="Center"
                               Padding="8,0,0,0">
							<Label.GestureRecognizers>
								<TapGestureRecognizer Command="{Binding ToggleMedicalEditCommand}"/>
							</Label.GestureRecognizers>
						</Label>
					</Grid>

					<!-- ── MEDICAL & HEALTH INFORMATION (combined) ── -->
					<Border Style="{StaticResource CardStyle}">
						<Border.StrokeShape>
							<RoundRectangle CornerRadius="14"/>
						</Border.StrokeShape>
						<VerticalStackLayout Spacing="0">
							<Label Text="MEDICAL &amp; HEALTH INFORMATION" Style="{StaticResource SectionTitleStyle}"/>

							<!-- VIEW MODE -->
							<VerticalStackLayout IsVisible="{Binding IsMedicalEditMode, Converter={StaticResource InvertedBoolConverter}}" Spacing="0">

								<!-- Blood Type -->
								<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
									<Label Grid.Column="0" Text="Blood Type" Style="{StaticResource RowLabelStyle}"/>
									<Label Grid.Column="1" Text="{Binding BloodType}" Style="{StaticResource RowValueStyle}"/>
								</Grid>
								<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>

								<!-- In Good Health -->
								<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
									<Label Grid.Column="0" Text="In Good Health" Style="{StaticResource RowLabelStyle}"/>
									<Label Grid.Column="1" Text="{Binding IsGoodHealth, Converter={StaticResource BoolToYesNoConverter}}" Style="{StaticResource RowValueStyle}"/>
								</Grid>
								<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>

								<!-- Under Medical Treatment + details -->
								<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
									<Label Grid.Column="0" Text="Under Medical Treatment" Style="{StaticResource RowLabelStyle}"/>
									<Label Grid.Column="1" Text="{Binding UnderMedicalTreatment, Converter={StaticResource BoolToYesNoConverter}}" Style="{StaticResource RowValueStyle}"/>
								</Grid>
								<Label Text="{Binding MedicationDetails}"
									   FontSize="13" TextColor="{StaticResource TextSecondary}"
									   Margin="0,0,0,12"
									   IsVisible="{Binding UnderMedicalTreatment}"/>
								<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>

								<!-- Been Hospitalized + details -->
								<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
									<Label Grid.Column="0" Text="Been Hospitalized" Style="{StaticResource RowLabelStyle}"/>
									<Label Grid.Column="1" Text="{Binding HasBeenHospitalized, Converter={StaticResource BoolToYesNoConverter}}" Style="{StaticResource RowValueStyle}"/>
								</Grid>
								<Label Text="{Binding HospitalizationDetails}"
									   FontSize="13" TextColor="{StaticResource TextSecondary}"
									   Margin="0,0,0,12"
									   IsVisible="{Binding HasBeenHospitalized}"/>
								<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>

								<!-- Taking Medications + details -->
								<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
									<Label Grid.Column="0" Text="Taking Medications" Style="{StaticResource RowLabelStyle}"/>
									<Label Grid.Column="1" Text="{Binding TakingMedications, Converter={StaticResource BoolToYesNoConverter}}" Style="{StaticResource RowValueStyle}"/>
								</Grid>
								<Label Text="{Binding MedicationDetails}"
									   FontSize="13" TextColor="{StaticResource TextSecondary}"
									   Margin="0,0,0,12"
									   IsVisible="{Binding TakingMedications}"/>
								<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>

								<!-- Uses Tobacco -->
								<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
									<Label Grid.Column="0" Text="Uses Tobacco" Style="{StaticResource RowLabelStyle}"/>
									<Label Grid.Column="1" Text="{Binding UsesTobacco, Converter={StaticResource BoolToYesNoConverter}}" Style="{StaticResource RowValueStyle}"/>
								</Grid>
								<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>

								<!-- Pregnant — only visible for female patients -->
								<Grid ColumnDefinitions="*,*" Margin="0,0,0,0"
									  IsVisible="{Binding IsFemale}">
									<Label Grid.Column="0" Text="Pregnant" Style="{StaticResource RowLabelStyle}"/>
									<Label Grid.Column="1" Text="{Binding IsPregnant, Converter={StaticResource BoolToYesNoConverter}}" Style="{StaticResource RowValueStyle}"/>
								</Grid>

							</VerticalStackLayout>

							<!-- EDIT MODE -->
							<VerticalStackLayout IsVisible="{Binding IsMedicalEditMode}" Spacing="0">

								<!-- Blood Type -->
								<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
									<Label Grid.Column="0" Text="Blood Type" Style="{StaticResource RowLabelStyle}" VerticalOptions="Center"/>
									<Entry Grid.Column="1" Text="{Binding BloodType}"
										   HorizontalTextAlignment="End" FontSize="14"
										   MinimumHeightRequest="44" BackgroundColor="Transparent"/>
								</Grid>
								<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>

								<!-- In Good Health -->
								<Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
									<Label Grid.Column="0" Text="In Good Health" Style="{StaticResource RowLabelStyle}"/>
									<CheckBox Grid.Column="1" IsChecked="{Binding IsGoodHealth}" Color="{StaticResource PrimaryPink}"/>
								</Grid>

								<!-- Under Medical Treatment + inline details -->
								<Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
									<Label Grid.Column="0" Text="Under Medical Treatment" Style="{StaticResource RowLabelStyle}"/>
									<CheckBox Grid.Column="1" IsChecked="{Binding UnderMedicalTreatment}" Color="{StaticResource PrimaryPink}"/>
								</Grid>
								<VerticalStackLayout IsVisible="{Binding UnderMedicalTreatment}" Spacing="2" Margin="16,0,0,8">
									<Label Text="Condition being treated:" FontSize="12" TextColor="{StaticResource TextMuted}"/>
									<Editor Text="{Binding MedicationDetails}"
											FontSize="14" BackgroundColor="Transparent"
											MinimumHeightRequest="52"/>
								</VerticalStackLayout>

								<!-- Been Hospitalized + inline details -->
								<Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
									<Label Grid.Column="0" Text="Been Hospitalized" Style="{StaticResource RowLabelStyle}"/>
									<CheckBox Grid.Column="1" IsChecked="{Binding HasBeenHospitalized}" Color="{StaticResource PrimaryPink}"/>
								</Grid>
								<VerticalStackLayout IsVisible="{Binding HasBeenHospitalized}" Spacing="2" Margin="16,0,0,8">
									<Label Text="When and why:" FontSize="12" TextColor="{StaticResource TextMuted}"/>
									<Editor Text="{Binding HospitalizationDetails}"
											FontSize="14" BackgroundColor="Transparent"
											MinimumHeightRequest="52"/>
								</VerticalStackLayout>

								<!-- Taking Medications + inline details -->
								<Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
									<Label Grid.Column="0" Text="Taking Medications" Style="{StaticResource RowLabelStyle}"/>
									<CheckBox Grid.Column="1" IsChecked="{Binding TakingMedications}" Color="{StaticResource PrimaryPink}"/>
								</Grid>
								<VerticalStackLayout IsVisible="{Binding TakingMedications}" Spacing="2" Margin="16,0,0,8">
									<Label Text="Please specify:" FontSize="12" TextColor="{StaticResource TextMuted}"/>
									<Editor Text="{Binding MedicationDetails}"
											FontSize="14" BackgroundColor="Transparent"
											MinimumHeightRequest="52"/>
								</VerticalStackLayout>

								<!-- Uses Tobacco -->
								<Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
									<Label Grid.Column="0" Text="Uses Tobacco" Style="{StaticResource RowLabelStyle}"/>
									<CheckBox Grid.Column="1" IsChecked="{Binding UsesTobacco}" Color="{StaticResource PrimaryPink}"/>
								</Grid>

								<!-- Pregnant — only for female patients -->
								<Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8"
									  IsVisible="{Binding IsFemale}">
									<Label Grid.Column="0" Text="Pregnant" Style="{StaticResource RowLabelStyle}"/>
									<CheckBox Grid.Column="1" IsChecked="{Binding IsPregnant}" Color="{StaticResource PrimaryPink}"/>
								</Grid>

							</VerticalStackLayout>
						</VerticalStackLayout>
					</Border>

					<!-- ── ALLERGIES — alphabetical ── -->
					<Border Style="{StaticResource CardStyle}">
						<Border.StrokeShape>
							<RoundRectangle CornerRadius="14"/>
						</Border.StrokeShape>
						<VerticalStackLayout Spacing="0">
							<Label Text="ALLERGIES" Style="{StaticResource SectionTitleStyle}"/>

							<!-- VIEW MODE -->
							<VerticalStackLayout IsVisible="{Binding IsMedicalEditMode, Converter={StaticResource InvertedBoolConverter}}" Spacing="0">
								<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
									<Label Grid.Column="0" Text="Aspirin" Style="{StaticResource RowLabelStyle}"/>
									<Label Grid.Column="1" Text="{Binding HasAspirinAllergy, Converter={StaticResource BoolToYesNoConverter}}" Style="{StaticResource RowValueStyle}"/>
								</Grid>
								<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>
								<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
									<Label Grid.Column="0" Text="Latex" Style="{StaticResource RowLabelStyle}"/>
									<Label Grid.Column="1" Text="{Binding HasLatexAllergy, Converter={StaticResource BoolToYesNoConverter}}" Style="{StaticResource RowValueStyle}"/>
								</Grid>
								<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>
								<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
									<Label Grid.Column="0" Text="Local Anesthetic" Style="{StaticResource RowLabelStyle}"/>
									<Label Grid.Column="1" Text="{Binding HasLocalAnestheticAllergy, Converter={StaticResource BoolToYesNoConverter}}" Style="{StaticResource RowValueStyle}"/>
								</Grid>
								<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>
								<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
									<Label Grid.Column="0" Text="Penicillin" Style="{StaticResource RowLabelStyle}"/>
									<Label Grid.Column="1" Text="{Binding HasPenicillinAllergy, Converter={StaticResource BoolToYesNoConverter}}" Style="{StaticResource RowValueStyle}"/>
								</Grid>
								<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>
								<Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
									<Label Grid.Column="0" Text="Sulfa" Style="{StaticResource RowLabelStyle}"/>
									<Label Grid.Column="1" Text="{Binding HasSulfaAllergy, Converter={StaticResource BoolToYesNoConverter}}" Style="{StaticResource RowValueStyle}"/>
								</Grid>
								<BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,12"/>
								<Grid ColumnDefinitions="*,*" Margin="0,0,0,0">
									<Label Grid.Column="0" Text="Other" Style="{StaticResource RowLabelStyle}"/>
									<Label Grid.Column="1" Text="{Binding OtherAllergy}" Style="{StaticResource RowValueStyle}"/>
								</Grid>
							</VerticalStackLayout>

							<!-- EDIT MODE -->
							<VerticalStackLayout IsVisible="{Binding IsMedicalEditMode}" Spacing="0">
								<Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
									<Label Grid.Column="0" Text="Aspirin" Style="{StaticResource RowLabelStyle}"/>
									<CheckBox Grid.Column="1" IsChecked="{Binding HasAspirinAllergy}" Color="{StaticResource PrimaryPink}"/>
								</Grid>
								<Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
									<Label Grid.Column="0" Text="Latex" Style="{StaticResource RowLabelStyle}"/>
									<CheckBox Grid.Column="1" IsChecked="{Binding HasLatexAllergy}" Color="{StaticResource PrimaryPink}"/>
								</Grid>
								<Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
									<Label Grid.Column="0" Text="Local Anesthetic" Style="{StaticResource RowLabelStyle}"/>
									<CheckBox Grid.Column="1" IsChecked="{Binding HasLocalAnestheticAllergy}" Color="{StaticResource PrimaryPink}"/>
								</Grid>
								<Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
									<Label Grid.Column="0" Text="Penicillin" Style="{StaticResource RowLabelStyle}"/>
									<CheckBox Grid.Column="1" IsChecked="{Binding HasPenicillinAllergy}" Color="{StaticResource PrimaryPink}"/>
								</Grid>
								<Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
									<Label Grid.Column="0" Text="Sulfa" Style="{StaticResource RowLabelStyle}"/>
									<CheckBox Grid.Column="1" IsChecked="{Binding HasSulfaAllergy}" Color="{StaticResource PrimaryPink}"/>
								</Grid>
								<Label Text="Other" Style="{StaticResource RowLabelStyle}" Margin="0,0,0,8"/>
								<Entry Text="{Binding OtherAllergy}"
                                       FontSize="14" BackgroundColor="Transparent"/>
							</VerticalStackLayout>
						</VerticalStackLayout>
					</Border>

					<!-- ── MEDICAL CONDITIONS ── -->
					<Border Style="{StaticResource CardStyle}">
						<Border.StrokeShape>
							<RoundRectangle CornerRadius="14"/>
						</Border.StrokeShape>
						<VerticalStackLayout Spacing="0">
							<Label Text="MEDICAL CONDITIONS" Style="{StaticResource SectionTitleStyle}"/>

							<!-- VIEW MODE: comma-separated summary -->
							<Label Text="{Binding ConditionsText}"
                                   Style="{StaticResource BodyStyle}"
                                   IsVisible="{Binding IsMedicalEditMode, Converter={StaticResource InvertedBoolConverter}}"/>

							<!-- EDIT MODE: 2-col checklist, alphabetical, Other last -->
							<CollectionView ItemsSource="{Binding Conditions}"
                                            IsVisible="{Binding IsMedicalEditMode}">
								<CollectionView.ItemsLayout>
									<GridItemsLayout Orientation="Vertical" Span="2"
                                                     HorizontalItemSpacing="8" VerticalItemSpacing="4"/>
								</CollectionView.ItemsLayout>
								<CollectionView.ItemTemplate>
									<DataTemplate x:DataType="vm:ConditionCheckItem">
										<HorizontalStackLayout Spacing="8" Padding="0,4">
											<CheckBox IsChecked="{Binding IsSelected}"
                                                      Color="{StaticResource PrimaryPink}"
                                                      VerticalOptions="Center"/>
											<Label Text="{Binding ConditionName}"
                                                   FontSize="13"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   VerticalOptions="Center"/>
										</HorizontalStackLayout>
									</DataTemplate>
								</CollectionView.ItemTemplate>
							</CollectionView>
						</VerticalStackLayout>
					</Border>

				</VerticalStackLayout>

			</VerticalStackLayout>
		</ScrollView>

		<!-- ══ ROW 3: SAVE BUTTON ══ -->
		<Border Grid.Row="3"
                IsVisible="{Binding IsPersonalEditMode}"
                BackgroundColor="{StaticResource PageBg}"
                StrokeThickness="0"
                Padding="16,0,16,16">
			<Button Text="Save Changes"
                    Command="{Binding SavePersonalRecordCommand}"
                    IsEnabled="{Binding IsSavingPersonal, Converter={StaticResource InvertedBoolConverter}}"
                    Style="{StaticResource PrimaryButtonStyle}"/>
		</Border>

		<Border Grid.Row="3"
                IsVisible="{Binding IsMedicalEditMode}"
                BackgroundColor="{StaticResource PageBg}"
                StrokeThickness="0"
                Padding="16,0,16,16">
			<Button Text="Save Changes"
                    Command="{Binding UpdateMedicalRecordCommand}"
                    IsEnabled="{Binding IsSavingMedical, Converter={StaticResource InvertedBoolConverter}}"
                    Style="{StaticResource PrimaryButtonStyle}"/>
		</Border>

	</Grid>
</ContentPage>
