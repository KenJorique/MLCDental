<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:ClinicApp.ViewModels.PatientsRelatedVM"
    x:Class="ClinicApp.Views.PatientsRelated.PatientListPage"
    Title="Patients"
    Shell.NavBarIsVisible="True"
    Shell.BackgroundColor="{StaticResource PrimaryPink}"
    Shell.TitleColor="White"
    Shell.ForegroundColor="White"
    Shell.TabBarIsVisible="True"
    BackgroundColor="{StaticResource PageBg}">

	<Grid RowDefinitions="Auto,*">

		<!-- ── SEARCH + SORT ── -->
		<VerticalStackLayout Grid.Row="0"
                             BackgroundColor="{StaticResource PrimaryPink}"
                             Padding="16,10,16,14">
			<Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
				<Border Grid.Column="0" BackgroundColor="White"
                        StrokeThickness="0" HeightRequest="40">
					<Border.StrokeShape>
						<RoundRectangle CornerRadius="20"/>
					</Border.StrokeShape>
					<Grid ColumnDefinitions="Auto,*" Padding="12,0" ColumnSpacing="8">
						<Label Grid.Column="0" FontFamily="MaterialSymbolsRounded"
                               Text="&#xe8b6;" FontSize="17"
                               TextColor="{StaticResource TextMuted}"
                               VerticalOptions="Center"/>
						<Entry Grid.Column="1"
                               Text="{Binding SearchText}"
                               Placeholder="Search Name..."
                               PlaceholderColor="{StaticResource TextMuted}"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="13" BackgroundColor="Transparent"
                               VerticalOptions="Center"/>
					</Grid>
				</Border>

				<Border Grid.Column="1" BackgroundColor="Transparent"
                        StrokeThickness="0" HeightRequest="40" WidthRequest="40"
                        VerticalOptions="Center">
					<Border.GestureRecognizers>
						<TapGestureRecognizer Command="{Binding ShowSortOptionsCommand}"/>
					</Border.GestureRecognizers>
					<Label FontFamily="MaterialSymbolsRounded" Text="&#xe152;"
                           FontSize="24" TextColor="White"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
				</Border>
			</Grid>
		</VerticalStackLayout>

		<!-- ── PATIENT LIST ── -->
		<CollectionView Grid.Row="1"
                        ItemsSource="{Binding Patients}"
                        Margin="16,14,16,88"
                        IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}">

			<CollectionView.EmptyView>
				<VerticalStackLayout Spacing="8" HorizontalOptions="Center"
                                     VerticalOptions="Center" Margin="0,60,0,0">
					<Label Text="No patients found"
                           FontSize="16" FontAttributes="Bold"
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalTextAlignment="Center"/>
					<Label Text="Tap + Add Patient to get started"
                           FontSize="13" TextColor="{StaticResource TextMuted}"
                           HorizontalTextAlignment="Center"/>
				</VerticalStackLayout>
			</CollectionView.EmptyView>

			<CollectionView.ItemTemplate>
				<DataTemplate x:DataType="vm:PatientCardViewModel">

					<!-- Simple clean folder card: tab strip + card body -->
					<Grid Margin="0,0,0,14" RowDefinitions="14,Auto" RowSpacing="0">

						<!-- Tab strip -->
						<Border Grid.Row="0"
                                BackgroundColor="#C8A84B"
                                StrokeThickness="0"
                                WidthRequest="100"
                                HorizontalOptions="Start"
                                Margin="18,0,0,0">
							<Border.StrokeShape>
								<RoundRectangle CornerRadius="6,6,0,0"/>
							</Border.StrokeShape>
						</Border>

						<!-- Card body -->
						<Border Grid.Row="1"
                                BackgroundColor="#F5F0D0"
                                StrokeThickness="0"
                                Padding="16,12,16,14">
							<Border.StrokeShape>
								<RoundRectangle CornerRadius="0,10,10,10"/>
							</Border.StrokeShape>
							<Border.GestureRecognizers>
								<TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                              Path=BindingContext.OpenActionSheetCommand}"
                                    CommandParameter="{Binding .}"/>
							</Border.GestureRecognizers>

							<Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto"
                                  RowSpacing="3" ColumnSpacing="8">

								<!-- Row 1: Patient ID -->
								<Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                       Text="{Binding Patient.PatientID, StringFormat='Patient ID: {0:D3}'}"
                                       FontSize="11" TextColor="#777777"/>

								<!-- Row 2: Patient Name -->
								<Label Grid.Row="1" Grid.Column="0"
                                       Text="{Binding Patient.FullName}"
                                       FontSize="16" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"
                                       LineBreakMode="TailTruncation"
                                       VerticalOptions="Center"/>

								<!-- Call button spans rows 2 & 3 -->
								<Border Grid.Row="1" Grid.Column="1" Grid.RowSpan="2"
                                        BackgroundColor="{StaticResource PrimaryPink}"
                                        StrokeThickness="0"
                                        HeightRequest="38" WidthRequest="38"
                                        VerticalOptions="Center">
									<Border.StrokeShape>
										<RoundRectangle CornerRadius="19"/>
									</Border.StrokeShape>
									<Border.GestureRecognizers>
										<TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                      Path=BindingContext.CallPatientCommand}"
                                            CommandParameter="{Binding .}"/>
									</Border.GestureRecognizers>
									<Label FontFamily="MaterialSymbolsRounded"
                                           Text="&#xe0b0;"
                                           FontSize="18" TextColor="White"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
								</Border>

								<!-- Row 3: Phone number -->
								<Label Grid.Row="2" Grid.Column="0"
                                       Text="{Binding Patient.MobileNo}"
                                       FontSize="13" TextColor="#555555"
                                       VerticalOptions="Center"/>

							</Grid>
						</Border>
					</Grid>

				</DataTemplate>
			</CollectionView.ItemTemplate>

		</CollectionView>

		<!-- Loading -->
		<VerticalStackLayout Grid.Row="1"
                             IsVisible="{Binding IsBusy}"
                             HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
			<ActivityIndicator IsRunning="{Binding IsBusy}"
                               Color="{StaticResource PrimaryPink}"
                               HeightRequest="36" WidthRequest="36"/>
			<Label Text="Loading patients..." FontSize="12"
                   TextColor="{StaticResource TextMuted}"
                   HorizontalTextAlignment="Center"/>
		</VerticalStackLayout>

		<!-- FAB -->
		<Button Grid.Row="1"
                Text="+ Add Patient"
                Command="{Binding GoToAddPatientCommand}"
                Style="{StaticResource FabStyle}"
                VerticalOptions="End" HorizontalOptions="End"
                Margin="0,0,20,24"/>

	</Grid>
</ContentPage>
