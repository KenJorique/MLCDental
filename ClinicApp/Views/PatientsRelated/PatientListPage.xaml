<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ClinicApp.ViewModels.PatientsRelatedVM"
             x:Class="ClinicApp.Views.PatientsRelated.PatientListPage"
             Title="Patients"
             Shell.TabBarIsVisible="True">

    <Grid>

        <RefreshView Command="{Binding RefreshCommand}"
                     IsRefreshing="{Binding IsRefreshing}">

            <CollectionView ItemsSource="{Binding Patients}" Margin="10">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:PatientCardViewModel">

                        <Frame Margin="5" Padding="12">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                              Path=BindingContext.ToggleExpandCommand}"
                                    CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>

                            <VerticalStackLayout Spacing="10">

                                <Label FontSize="16" FontAttributes="Bold">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding Patient.FirstName}" />
                                            <Span Text=" " />
                                            <Span Text="{Binding Patient.LastName}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                                <Grid ColumnDefinitions="*,*,*,*,*"
                                      ColumnSpacing="8"
                                      IsVisible="{Binding IsExpanded}">

                                    <Button Grid.Column="0" Text="📄"
                                            HeightRequest="80" FontSize="28"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                      Path=BindingContext.ViewPatientCommand}"
                                            CommandParameter="{Binding .}" />

                                    <Button Grid.Column="1" Text="🦷"
                                            HeightRequest="80" FontSize="28"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                      Path=BindingContext.ViewDentalChartCommand}"
                                            CommandParameter="{Binding .}" />

                                    <Button Grid.Column="2" Text="📋"
                                            HeightRequest="80" FontSize="28"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                      Path=BindingContext.ViewTreatmentHistoryCommand}"
                                            CommandParameter="{Binding .}" />

                                    <Button Grid.Column="3" Text="💀"
                                            HeightRequest="80" FontSize="28"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                      Path=BindingContext.GoToCephalometricCommand}"
                                            CommandParameter="{Binding .}" />

                                    <!-- Add as Grid.Column="4" or in a new row -->
                                    <Button Grid.Column="4"
                                            Text="💳"
                                            HeightRequest="80"
                                            FontSize="28"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                      Path=BindingContext.ViewTransactionsCommand}"
                                            CommandParameter="{Binding .}"/>

                                </Grid>
                            </VerticalStackLayout>
                        </Frame>

                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </RefreshView>

        <Button Text="+ Add Patient"
                Command="{Binding GoToAddPatientCommand}"
                VerticalOptions="End"
                HorizontalOptions="End"
                Margin="0,0,20,20"
                CornerRadius="30"
                Padding="20,12" />

    </Grid>
</ContentPage>