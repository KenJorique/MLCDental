<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:ClinicApp.ViewModels.PatientsRelatedVM"
    x:Class="ClinicApp.Views.PatientsRelated.PatientListPage"
    Title="Patients"
    Shell.NavBarIsVisible="True"
    Shell.BackgroundColor="{StaticResource PrimaryPink}"
    Shell.TitleColor="White"
    Shell.ForegroundColor="White"
    Shell.TabBarIsVisible="True"
    BackgroundColor="{StaticResource PageBg}">

	<Grid RowDefinitions="Auto,*">

		<!-- ── SEARCH + SORT BAR (sits directly under navbar) ── -->
		<VerticalStackLayout Grid.Row="0"
                             BackgroundColor="{StaticResource PrimaryPink}"
                             Padding="16,0,16,14">
			<Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">

				<Border Grid.Column="0"
                        BackgroundColor="White"
                        StrokeThickness="0"
                        HeightRequest="40">
					<Border.StrokeShape>
						<RoundRectangle CornerRadius="20"/>
					</Border.StrokeShape>
					<Grid ColumnDefinitions="Auto,*" Padding="12,0" ColumnSpacing="8">
						<Label Grid.Column="0"
                               FontFamily="MaterialSymbolsRounded"
                               Text="&#xe8b6;"
                               FontSize="17"
                               TextColor="{StaticResource TextMuted}"
                               VerticalOptions="Center"/>
						<Entry Grid.Column="1"
                               Text="{Binding SearchText}"
                               Placeholder="Search Name..."
                               PlaceholderColor="{StaticResource TextMuted}"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="13"
                               BackgroundColor="Transparent"
                               VerticalOptions="Center"/>
					</Grid>
				</Border>

				<Border Grid.Column="1"
                        BackgroundColor="Transparent"
                        StrokeThickness="0"
                        HeightRequest="40"
                        WidthRequest="40"
                        VerticalOptions="Center">
					<Border.GestureRecognizers>
						<TapGestureRecognizer Command="{Binding ShowSortOptionsCommand}"/>
					</Border.GestureRecognizers>
					<Label FontFamily="MaterialSymbolsRounded"
                           Text="&#xe152;"
                           FontSize="24"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
				</Border>

			</Grid>
		</VerticalStackLayout>

		<!-- ── PATIENT LIST ── -->
		<CollectionView Grid.Row="1"
                        ItemsSource="{Binding Patients}"
                        Margin="16,14,16,88"
                        IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}">

			<CollectionView.EmptyView>
				<VerticalStackLayout Spacing="8"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Margin="0,60,0,0">
					<Label Text="No patients found"
                           FontSize="16" FontAttributes="Bold"
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalTextAlignment="Center"/>
					<Label Text="Tap + Add Patient to get started"
                           FontSize="13"
                           TextColor="{StaticResource TextMuted}"
                           HorizontalTextAlignment="Center"/>
				</VerticalStackLayout>
			</CollectionView.EmptyView>

			<CollectionView.ItemTemplate>
				<DataTemplate x:DataType="vm:PatientCardViewModel">

					<Grid Margin="0,0,0,14" RowDefinitions="14,Auto" RowSpacing="0">

						<!-- Folder tab strip -->
						<Border Grid.Row="0"
                                BackgroundColor="#D4BC5A"
                                StrokeThickness="0"
                                WidthRequest="100"
                                HorizontalOptions="Start"
                                Margin="18,0,0,0">
							<Border.StrokeShape>
								<RoundRectangle CornerRadius="6,6,0,0"/>
							</Border.StrokeShape>
						</Border>

						<!-- Folder card body -->
						<Border Grid.Row="1"
                                BackgroundColor="#F5F0D0"
                                StrokeThickness="0"
                                Padding="16,18">
							<Border.StrokeShape>
								<RoundRectangle CornerRadius="12,12,12,12"/>
							</Border.StrokeShape>
							<Border.GestureRecognizers>
								<TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                              Path=BindingContext.OpenActionSheetCommand}"
                                    CommandParameter="{Binding .}"/>
							</Border.GestureRecognizers>

							<!-- 3-col: ID | divider | Name+Phone+Call -->
							<Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="0">

								<!-- Patient ID — top aligned -->
								<VerticalStackLayout Grid.Column="0"
                                                     VerticalOptions="Start"
                                                     Spacing="0"
                                                     Margin="0,0,14,0">
									<Label Text="Patient ID:"
                                           FontSize="10"
                                           TextColor="#777777"/>
									<Label Text="{Binding Patient.PatientID, StringFormat='{0:D3}'}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"/>
								</VerticalStackLayout>

								<!-- Vertical divider -->
								<BoxView Grid.Column="1"
                                         WidthRequest="1"
                                         BackgroundColor="#CCBA6A"
                                         VerticalOptions="Fill"
                                         Margin="0,2,14,2"/>

								<!-- Name + Phone + Call — top aligned -->
								<VerticalStackLayout Grid.Column="2"
                                                     Spacing="6"
                                                     VerticalOptions="Start">

									<Label Text="{Binding Patient.FullName}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"
                                           LineBreakMode="TailTruncation"/>

									<Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
										<Label Grid.Column="0"
                                               Text="{Binding Patient.MobileNo}"
                                               FontSize="14"
                                               TextColor="#555555"
                                               VerticalOptions="Center"/>
										<Border Grid.Column="1"
                                                BackgroundColor="{StaticResource PrimaryPink}"
                                                StrokeThickness="0"
                                                HeightRequest="36"
                                                WidthRequest="36"
                                                VerticalOptions="Center">
											<Border.StrokeShape>
												<RoundRectangle CornerRadius="18"/>
											</Border.StrokeShape>
											<Border.GestureRecognizers>
												<TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                              Path=BindingContext.CallPatientCommand}"
                                                    CommandParameter="{Binding .}"/>
											</Border.GestureRecognizers>
											<Label FontFamily="MaterialSymbolsRounded"
                                                   Text="&#xe0b0;"
                                                   FontSize="17"
                                                   TextColor="White"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
										</Border>
									</Grid>

								</VerticalStackLayout>

							</Grid>
						</Border>

					</Grid>

				</DataTemplate>
			</CollectionView.ItemTemplate>

		</CollectionView>

		<!-- Loading -->
		<VerticalStackLayout Grid.Row="1"
                             IsVisible="{Binding IsBusy}"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Spacing="8">
			<ActivityIndicator IsRunning="{Binding IsBusy}"
                               Color="{StaticResource PrimaryPink}"
                               HeightRequest="36" WidthRequest="36"/>
			<Label Text="Loading patients..."
                   FontSize="12"
                   TextColor="{StaticResource TextMuted}"
                   HorizontalTextAlignment="Center"/>
		</VerticalStackLayout>

		<!-- FAB -->
		<Button Grid.Row="1"
                Text="+ Add Patient"
                Command="{Binding GoToAddPatientCommand}"
                Style="{StaticResource FabStyle}"
                VerticalOptions="End"
                HorizontalOptions="End"
                Margin="0,0,20,24"/>

	</Grid>
</ContentPage>
