<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ClinicApp.ViewModels.PatientsRelatedVM"
             x:Class="ClinicApp.Views.PatientsRelated.AddPatientPage"
             x:DataType="vm:AddPatientViewModel"
             Title="{Binding PageTitle}"
             Shell.TabBarIsVisible="False">

    <ContentPage.Resources>
        <Style x:Key="SectionHeader" TargetType="Label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="TextColor" Value="#1A2B4A"/>
            <Setter Property="Margin" Value="0,18,0,6"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="Label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextColor" Value="#6B7A9A"/>
            <Setter Property="Margin" Value="0,8,0,2"/>
        </Style>
        <Style x:Key="FormEntry" TargetType="Entry">
            <Setter Property="BackgroundColor" Value="#F8FAFC"/>
            <Setter Property="TextColor" Value="#1A2B4A"/>
        </Style>
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="BackgroundColor" Value="White"/>
            <Setter Property="StrokeThickness" Value="0"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="12,10,12,30" Spacing="0">

            <!-- ══ A. PERSONAL INFORMATION ══ -->
            <Border Style="{StaticResource SectionCard}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#18000000" Offset="0,2" Radius="8"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="0">
                    <Label Text="👤  Personal Information" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="First Name *" Style="{StaticResource FieldLabel}"/>
                            <Entry Text="{Binding FirstName}" Placeholder="Juan" Style="{StaticResource FormEntry}"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Last Name *" Style="{StaticResource FieldLabel}"/>
                            <Entry Text="{Binding LastName}" Placeholder="dela Cruz" Style="{StaticResource FormEntry}"/>
                        </VerticalStackLayout>
                    </Grid>

                    <Label Text="Nickname" Style="{StaticResource FieldLabel}"/>
                    <Entry Text="{Binding Nickname}" Placeholder="Optional" Style="{StaticResource FormEntry}"/>

                    <Label Text="Gender" Style="{StaticResource FieldLabel}"/>
                    <Picker ItemsSource="{Binding GenderOptions}"
                            SelectedItem="{Binding SelectedGender}"
                            BackgroundColor="#F8FAFC"/>

                    <Label Text="Date of Birth" Style="{StaticResource FieldLabel}"/>
                    <DatePicker Date="{Binding DateOfBirth}" BackgroundColor="#F8FAFC"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="Nationality" Style="{StaticResource FieldLabel}"/>
                            <Entry Text="{Binding Nationality}" Placeholder="Filipino" Style="{StaticResource FormEntry}"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Religion" Style="{StaticResource FieldLabel}"/>
                            <Entry Text="{Binding Religion}" Placeholder="Optional" Style="{StaticResource FormEntry}"/>
                        </VerticalStackLayout>
                    </Grid>

                    <Label Text="Occupation" Style="{StaticResource FieldLabel}"/>
                    <Entry Text="{Binding Occupation}" Placeholder="Optional" Style="{StaticResource FormEntry}"/>

                    <Label Text="Address" Style="{StaticResource FieldLabel}"/>
                    <Editor Text="{Binding Address}" Placeholder="House/Unit, Street, City"
                            MinimumHeightRequest="60" BackgroundColor="#F8FAFC"/>
                </VerticalStackLayout>
            </Border>

            <!-- ══ B. CONTACT DETAILS ══ -->
            <Border Style="{StaticResource SectionCard}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#18000000" Offset="0,2" Radius="8"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="0">
                    <Label Text="📞  Contact Details" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="Mobile No." Style="{StaticResource FieldLabel}"/>
                            <Entry Text="{Binding MobileNo}" Keyboard="Telephone"
                                   Placeholder="09xxxxxxxxx" Style="{StaticResource FormEntry}"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Home No." Style="{StaticResource FieldLabel}"/>
                            <Entry Text="{Binding HomeNo}" Keyboard="Telephone"
                                   Placeholder="Optional" Style="{StaticResource FormEntry}"/>
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="Office No." Style="{StaticResource FieldLabel}"/>
                            <Entry Text="{Binding OfficeNo}" Keyboard="Telephone"
                                   Placeholder="Optional" Style="{StaticResource FormEntry}"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Fax No." Style="{StaticResource FieldLabel}"/>
                            <Entry Text="{Binding FaxNo}" Keyboard="Telephone"
                                   Placeholder="Optional" Style="{StaticResource FormEntry}"/>
                        </VerticalStackLayout>
                    </Grid>

                    <Label Text="Email Address" Style="{StaticResource FieldLabel}"/>
                    <Entry Text="{Binding Email}" Keyboard="Email"
                           Placeholder="email@example.com" Style="{StaticResource FormEntry}"/>
                </VerticalStackLayout>
            </Border>

            <!-- ══ C. REFERRAL &amp; INSURANCE ══ -->
            <Border Style="{StaticResource SectionCard}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#18000000" Offset="0,2" Radius="8"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="0">
                    <Label Text="🏥  Referral &amp; Insurance" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>

                    <Label Text="Referred By" Style="{StaticResource FieldLabel}"/>
                    <Entry Text="{Binding ReferredBy}" Placeholder="Doctor / Friend / Walk-in"
                           Style="{StaticResource FormEntry}"/>

                    <Label Text="Reason for Consultation" Style="{StaticResource FieldLabel}"/>
                    <Editor Text="{Binding ReasonForConsultation}" Placeholder="Chief complaint or reason"
                            MinimumHeightRequest="60" BackgroundColor="#F8FAFC"/>

                    <HorizontalStackLayout Spacing="10" Margin="0,10,0,0">
                        <CheckBox IsChecked="{Binding HasInsurance}"/>
                        <Label Text="Has Dental Insurance" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <VerticalStackLayout IsVisible="{Binding HasInsurance}" Spacing="0">
                        <Label Text="Insurance Provider" Style="{StaticResource FieldLabel}"/>
                        <Entry Text="{Binding DentalInsurance}" Placeholder="e.g. PhilHealth, Maxicare"
                               Style="{StaticResource FormEntry}"/>
                        <Label Text="Effective Date" Style="{StaticResource FieldLabel}"/>
                        <DatePicker Date="{Binding InsuranceEffectiveDate}" BackgroundColor="#F8FAFC"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- ══ D. GUARDIAN ══ -->
            <Border Style="{StaticResource SectionCard}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#18000000" Offset="0,2" Radius="8"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="0">
                    <Label Text="👪  Guardian / Emergency Contact" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>

                    <Label Text="Guardian Name" Style="{StaticResource FieldLabel}"/>
                    <Entry Text="{Binding GuardianName}" Placeholder="Full name (if applicable)"
                           Style="{StaticResource FormEntry}"/>

                    <Label Text="Relationship to Patient" Style="{StaticResource FieldLabel}"/>
                    <Picker ItemsSource="{Binding RelationshipOptions}"
                            SelectedItem="{Binding GuardianRelationship}"
                            BackgroundColor="#F8FAFC"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="Guardian Occupation" Style="{StaticResource FieldLabel}"/>
                            <Entry Text="{Binding GuardianOccupation}" Placeholder="Optional"
                                   Style="{StaticResource FormEntry}"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Guardian Mobile No." Style="{StaticResource FieldLabel}"/>
                            <Entry Text="{Binding GuardianMobileNo}" Keyboard="Telephone"
                                   Placeholder="09xxxxxxxxx" Style="{StaticResource FormEntry}"/>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ══ E. MEDICAL HISTORY ══ -->
            <Border Style="{StaticResource SectionCard}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#18000000" Offset="0,2" Radius="8"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="0">
                    <Label Text="🩺  Medical History" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="Blood Type" Style="{StaticResource FieldLabel}"/>
                            <Picker ItemsSource="{Binding BloodTypeOptions}"
                                    SelectedItem="{Binding BloodType}"
                                    BackgroundColor="#F8FAFC"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Blood Pressure" Style="{StaticResource FieldLabel}"/>
                            <Entry Text="{Binding BloodPressure}" Placeholder="e.g. 120/80"
                                   Style="{StaticResource FormEntry}"/>
                        </VerticalStackLayout>
                    </Grid>

                    <Label Text="Physician / Doctor Name" Style="{StaticResource FieldLabel}"/>
                    <Entry Text="{Binding PhysicianName}" Placeholder="Optional"
                           Style="{StaticResource FormEntry}"/>

                    <!-- Yes/No flags -->
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="10" Margin="0,10,0,0">
                        <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="8">
                            <CheckBox IsChecked="{Binding IsGoodHealth}"/>
                            <Label Text="Good Health" VerticalOptions="Center" FontSize="13"/>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="8">
                            <CheckBox IsChecked="{Binding IsPregnant}"/>
                            <Label Text="Pregnant" VerticalOptions="Center" FontSize="13"/>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="8">
                            <CheckBox IsChecked="{Binding UsesTobacco}"/>
                            <Label Text="Uses Tobacco" VerticalOptions="Center" FontSize="13"/>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="8">
                            <CheckBox IsChecked="{Binding UsesAlcohol}"/>
                            <Label Text="Uses Alcohol" VerticalOptions="Center" FontSize="13"/>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Grid.Row="2" Grid.Column="0" Spacing="8">
                            <CheckBox IsChecked="{Binding TakingMedications}"/>
                            <Label Text="On Medications" VerticalOptions="Center" FontSize="13"/>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Grid.Row="2" Grid.Column="1" Spacing="8">
                            <CheckBox IsChecked="{Binding UnderMedicalTreatment}"/>
                            <Label Text="Under Treatment" VerticalOptions="Center" FontSize="13"/>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Grid.Row="3" Grid.Column="0" Spacing="8">
                            <CheckBox IsChecked="{Binding HasBeenHospitalized}"/>
                            <Label Text="Hospitalized" VerticalOptions="Center" FontSize="13"/>
                        </HorizontalStackLayout>
                    </Grid>

                    <Label Text="Medication Details" Style="{StaticResource FieldLabel}"
                           IsVisible="{Binding TakingMedications}"/>
                    <Editor Text="{Binding MedicationDetails}" Placeholder="List medications..."
                            MinimumHeightRequest="60" BackgroundColor="#F8FAFC"
                            IsVisible="{Binding TakingMedications}"/>

                    <Label Text="Hospitalization Details" Style="{StaticResource FieldLabel}"
                           IsVisible="{Binding HasBeenHospitalized}"/>
                    <Editor Text="{Binding HospitalizationDetails}" Placeholder="Reason, hospital, year..."
                            MinimumHeightRequest="60" BackgroundColor="#F8FAFC"
                            IsVisible="{Binding HasBeenHospitalized}"/>

                    <Label Text="Bleeding Time" Style="{StaticResource FieldLabel}"/>
                    <Entry Text="{Binding BleedingTime}" Placeholder="e.g. 3 minutes"
                           Style="{StaticResource FormEntry}"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="Previous Dentist" Style="{StaticResource FieldLabel}"/>
                            <Entry Text="{Binding PreviousDentist}" Placeholder="Optional"
                                   Style="{StaticResource FormEntry}"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Last Dental Visit" Style="{StaticResource FieldLabel}"/>
                            <Entry Text="{Binding LastDentalVisit}" Placeholder="e.g. Jan 2024"
                                   Style="{StaticResource FormEntry}"/>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ══ F. ALLERGIES ══ -->
            <Border Style="{StaticResource SectionCard}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#18000000" Offset="0,2" Radius="8"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="0">
                    <Label Text="⚠️  Allergies" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="10">
                        <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="8">
                            <CheckBox IsChecked="{Binding HasLatexAllergy}"/>
                            <Label Text="Latex" VerticalOptions="Center" FontSize="13"/>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="8">
                            <CheckBox IsChecked="{Binding HasAspirinAllergy}"/>
                            <Label Text="Aspirin" VerticalOptions="Center" FontSize="13"/>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="8">
                            <CheckBox IsChecked="{Binding HasPenicillinAllergy}"/>
                            <Label Text="Penicillin" VerticalOptions="Center" FontSize="13"/>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="8">
                            <CheckBox IsChecked="{Binding HasSulfaAllergy}"/>
                            <Label Text="Sulfa" VerticalOptions="Center" FontSize="13"/>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Grid.Row="2" Grid.Column="0" Spacing="8">
                            <CheckBox IsChecked="{Binding HasLocalAnestheticAllergy}"/>
                            <Label Text="Local Anesthetic" VerticalOptions="Center" FontSize="13"/>
                        </HorizontalStackLayout>
                    </Grid>

                    <Label Text="Other Allergies" Style="{StaticResource FieldLabel}"/>
                    <Entry Text="{Binding OtherAllergy}" Placeholder="Specify if any"
                           Style="{StaticResource FormEntry}"/>
                </VerticalStackLayout>
            </Border>

            <!-- ══ G. MEDICAL CONDITIONS ══ -->
            <Border Style="{StaticResource SectionCard}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#18000000" Offset="0,2" Radius="8"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="0">
                    <Label Text="🏷️  Medical Conditions" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                    <Label Text="Check all that apply:" FontSize="12" TextColor="#6B7A9A" Margin="0,0,0,8"/>

                    <FlexLayout BindableLayout.ItemsSource="{Binding Conditions}"
                                Wrap="Wrap" Direction="Row">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:ConditionCheckItem">
                                <HorizontalStackLayout Spacing="6" Margin="0,4,16,4">
                                    <CheckBox IsChecked="{Binding IsSelected}"/>
                                    <Label Text="{Binding ConditionName}"
                                           VerticalOptions="Center" FontSize="13" TextColor="#374151"/>
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>
                </VerticalStackLayout>
            </Border>

            <!-- ══ SAVE BUTTON ══ -->
            <Button Text="Save Patient"
                    Command="{Binding SavePatientCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                    BackgroundColor="#1A2B4A"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="52"
                    FontSize="16"
                    FontAttributes="Bold"
                    Margin="0,8,0,0"/>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#1A2B4A"
                               HorizontalOptions="Center"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
