<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:ClinicApp.ViewModels.PatientsRelatedVM"
    x:Class="ClinicApp.Views.PatientsRelated.AddPatientPage"
    x:DataType="vm:AddPatientViewModel"
    Title="{Binding PageTitle}"
    BackgroundColor="{StaticResource PageBg}"
    Shell.TabBarIsVisible="False">

	<Grid RowDefinitions="*,Auto">
		<ScrollView Grid.Row="0">
			<VerticalStackLayout Padding="20,-15,20,8" Spacing="0">

				<!-- ══ PERSONAL INFORMATION ══ -->
				<Label Text="PERSONAL INFORMATION" Style="{StaticResource FormSectionHeader}"/>

				<Grid ColumnDefinitions="*,*" ColumnSpacing="12">
					<VerticalStackLayout Grid.Column="0" Spacing="0">
						<HorizontalStackLayout Spacing="2">
							<Label Text="First Name" Style="{StaticResource FormFieldLabel}"/>
							<Label Text="*" Style="{StaticResource FormRequiredStar}"/>
						</HorizontalStackLayout>
						<Border Style="{StaticResource FormInputBox}">
							<Entry Text="{Binding FirstName}" Style="{StaticResource FormEntry}" Keyboard="Text"/>
						</Border>
					</VerticalStackLayout>
					<VerticalStackLayout Grid.Column="1" Spacing="0">
						<HorizontalStackLayout Spacing="2">
							<Label Text="Last Name" Style="{StaticResource FormFieldLabel}"/>
							<Label Text="*" Style="{StaticResource FormRequiredStar}"/>
						</HorizontalStackLayout>
						<Border Style="{StaticResource FormInputBox}">
							<Entry Text="{Binding LastName}" Style="{StaticResource FormEntry}" Keyboard="Text"/>
						</Border>
					</VerticalStackLayout>
				</Grid>

				<Label Text="Nickname" Style="{StaticResource FormFieldLabel}"/>
				<Border Style="{StaticResource FormInputBox}">
					<Entry Text="{Binding Nickname}" Style="{StaticResource FormEntry}" Keyboard="Text"/>
				</Border>

				<HorizontalStackLayout Spacing="2">
					<Label Text="Gender" Style="{StaticResource FormFieldLabel}"/>
					<Label Text="*" Style="{StaticResource FormRequiredStar}"/>
				</HorizontalStackLayout>
				<Border Style="{StaticResource FormInputBox}">
					<Picker ItemsSource="{Binding GenderOptions}"
                            SelectedItem="{Binding SelectedGender}"
                            FontSize="14" BackgroundColor="Transparent"
                            VerticalOptions="Center"/>
				</Border>

				<HorizontalStackLayout Spacing="2">
					<Label Text="Date of Birth" Style="{StaticResource FormFieldLabel}"/>
					<Label Text="*" Style="{StaticResource FormRequiredStar}"/>
				</HorizontalStackLayout>
				<Border Style="{StaticResource FormInputBox}">
					<DatePicker Date="{Binding DateOfBirth}"
                                Format="M/dd/yyyy"
                                FontSize="14"
                                TextColor="{StaticResource TextPrimary}"
                                BackgroundColor="Transparent"
                                VerticalOptions="Center"/>
				</Border>

				<Grid ColumnDefinitions="*,*" ColumnSpacing="12">
					<VerticalStackLayout Grid.Column="0" Spacing="0">
						<Label Text="Nationality" Style="{StaticResource FormFieldLabel}"/>
						<Border Style="{StaticResource FormInputBox}">
							<Entry Text="{Binding Nationality}" Style="{StaticResource FormEntry}" Keyboard="Text"/>
						</Border>
					</VerticalStackLayout>
					<VerticalStackLayout Grid.Column="1" Spacing="0">
						<Label Text="Religion" Style="{StaticResource FormFieldLabel}"/>
						<Border Style="{StaticResource FormInputBox}">
							<Entry Text="{Binding Religion}" Style="{StaticResource FormEntry}" Keyboard="Text"/>
						</Border>
					</VerticalStackLayout>
				</Grid>

				<Grid ColumnDefinitions="*,*" ColumnSpacing="12">
					<VerticalStackLayout Grid.Column="0" Spacing="0">
						<Label Text="Occupation" Style="{StaticResource FormFieldLabel}"/>
						<Border Style="{StaticResource FormInputBox}">
							<Entry Text="{Binding Occupation}"
                                   Style="{StaticResource FormEntry}"
                                   Keyboard="Text"/>
						</Border>
					</VerticalStackLayout>
					<VerticalStackLayout Grid.Column="1" Spacing="0">
						<Label Text="Blood Type" Style="{StaticResource FormFieldLabel}"/>
						<Border Style="{StaticResource FormInputBox}">
							<Picker ItemsSource="{Binding BloodTypeOptions}"
                                    SelectedItem="{Binding BloodType}"
                                    FontSize="14" BackgroundColor="Transparent"
                                    VerticalOptions="Center"/>
						</Border>
					</VerticalStackLayout>
				</Grid>

				<HorizontalStackLayout Spacing="2">
					<Label Text="Address" Style="{StaticResource FormFieldLabel}"/>
					<Label Text="*" Style="{StaticResource FormRequiredStar}"/>
				</HorizontalStackLayout>
				<Border Style="{StaticResource FormInputBoxTall}">
					<Editor Text="{Binding Address}" Style="{StaticResource FormEditor}" Keyboard="Text"/>
				</Border>

				<!-- ══ CONTACT DETAILS ══ -->
				<Label Text="CONTACT DETAILS" Style="{StaticResource FormSectionHeader}"/>

				<HorizontalStackLayout Spacing="2">
					<Label Text="Mobile No." Style="{StaticResource FormFieldLabel}"/>
					<Label Text="*" Style="{StaticResource FormRequiredStar}"/>
				</HorizontalStackLayout>
				<Border Style="{StaticResource FormInputBox}">
					<Entry Text="{Binding MobileNo}" Keyboard="Telephone"
                           Style="{StaticResource FormEntry}"/>
				</Border>

				<Label Text="Email Address" Style="{StaticResource FormFieldLabel}"/>
				<Border Style="{StaticResource FormInputBox}">
					<Entry Text="{Binding Email}" Keyboard="Email"
                           Style="{StaticResource FormEntry}"/>
				</Border>

				<Label Text="Home No." Style="{StaticResource FormFieldLabel}"/>
				<Border Style="{StaticResource FormInputBox}">
					<Entry Text="{Binding HomeNo}" Keyboard="Telephone"
                           Style="{StaticResource FormEntry}"/>
				</Border>

				<Grid ColumnDefinitions="*,*" ColumnSpacing="12">
					<VerticalStackLayout Grid.Column="0" Spacing="0">
						<Label Text="Office No." Style="{StaticResource FormFieldLabel}"/>
						<Border Style="{StaticResource FormInputBox}">
							<Entry Text="{Binding OfficeNo}" Keyboard="Telephone"
                                   Style="{StaticResource FormEntry}"/>
						</Border>
					</VerticalStackLayout>
					<VerticalStackLayout Grid.Column="1" Spacing="0">
						<Label Text="Fax No." Style="{StaticResource FormFieldLabel}"/>
						<Border Style="{StaticResource FormInputBox}">
							<Entry Text="{Binding FaxNo}" Keyboard="Telephone"
                                   Style="{StaticResource FormEntry}"/>
						</Border>
					</VerticalStackLayout>
				</Grid>

				<!-- ══ GUARDIAN / EMERGENCY CONTACT ══ -->
				<Label Text="GUARDIAN / EMERGENCY CONTACT" Style="{StaticResource FormSectionHeader}"/>

				<HorizontalStackLayout Spacing="2">
					<Label Text="Guardian Name" Style="{StaticResource FormFieldLabel}"/>
					<Label Text="*" Style="{StaticResource FormRequiredStar}"
                           IsVisible="{Binding IsMinor}"/>
				</HorizontalStackLayout>
				<Border Style="{StaticResource FormInputBox}">
					<Entry Text="{Binding GuardianName}" Style="{StaticResource FormEntry}" Keyboard="Text"/>
				</Border>

				<Label Text="Relationship to Patient" Style="{StaticResource FormFieldLabel}"/>
				<Border Style="{StaticResource FormInputBox}">
					<Picker ItemsSource="{Binding RelationshipOptions}"
                            SelectedItem="{Binding GuardianRelationship}"
                            FontSize="14" BackgroundColor="Transparent"
                            VerticalOptions="Center"/>
				</Border>

				<Label Text="Guardian Occupation" Style="{StaticResource FormFieldLabel}"/>
				<Border Style="{StaticResource FormInputBox}">
					<Entry Text="{Binding GuardianOccupation}" Style="{StaticResource FormEntry}" Keyboard="Text"/>
				</Border>

				<HorizontalStackLayout Spacing="2">
					<Label Text="Guardian Mobile No." Style="{StaticResource FormFieldLabel}"/>
					<Label Text="*" Style="{StaticResource FormRequiredStar}"
                           IsVisible="{Binding IsMinor}"/>
				</HorizontalStackLayout>
				<Border Style="{StaticResource FormInputBox}">
					<Entry Text="{Binding GuardianMobileNo}" Keyboard="Telephone"
                           Style="{StaticResource FormEntry}"/>
				</Border>

				<!-- ══ HEALTH & MEDICAL STATUS ══ -->
				<Label Text="HEALTH STATUS" Style="{StaticResource FormSectionHeader}"/>
				<Label Text="Check all that apply:" FontSize="12"
                       TextColor="{StaticResource TextMuted}" Margin="0,0,0,6"/>

				<Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto"
                      RowSpacing="0" ColumnSpacing="0" Margin="0,0,0,4">
					<Grid Grid.Row="0" Grid.Column="0" ColumnDefinitions="Auto,*" ColumnSpacing="4">
						<CheckBox Grid.Column="0" IsChecked="{Binding IsGoodHealth}" Color="{StaticResource PrimaryGreen}"/>
						<Label Grid.Column="1" Text="Good Health" Style="{StaticResource FormCheckLabel}"/>
					</Grid>
					<Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="Auto,*" ColumnSpacing="4">
						<CheckBox Grid.Column="0" IsChecked="{Binding HasBeenHospitalized}" Color="{StaticResource PrimaryGreen}"/>
						<Label Grid.Column="1" Text="Hospitalized" Style="{StaticResource FormCheckLabel}"/>
					</Grid>
					<Grid Grid.Row="1" Grid.Column="0" ColumnDefinitions="Auto,*" ColumnSpacing="4">
						<CheckBox Grid.Column="0" IsChecked="{Binding TakingMedications}" Color="{StaticResource PrimaryGreen}"/>
						<Label Grid.Column="1" Text="On Medications" Style="{StaticResource FormCheckLabel}"/>
					</Grid>
					<Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="Auto,*" ColumnSpacing="4">
						<CheckBox Grid.Column="0" IsChecked="{Binding UnderMedicalTreatment}" Color="{StaticResource PrimaryGreen}"/>
						<Label Grid.Column="1" Text="Under Treatment" Style="{StaticResource FormCheckLabel}"/>
					</Grid>
					<Grid Grid.Row="2" Grid.Column="0" ColumnDefinitions="Auto,*" ColumnSpacing="4">
						<CheckBox Grid.Column="0" IsChecked="{Binding UsesTobacco}" Color="{StaticResource PrimaryGreen}"/>
						<Label Grid.Column="1" Text="Uses Tobacco" Style="{StaticResource FormCheckLabel}"/>
					</Grid>
					<Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="Auto,*" ColumnSpacing="4">
						<CheckBox Grid.Column="0" IsChecked="{Binding IsPregnant}" Color="{StaticResource PrimaryGreen}"
                                  IsVisible="{Binding IsFemale}"/>
						<Label Grid.Column="1" Text="Pregnant" Style="{StaticResource FormCheckLabel}"
                               IsVisible="{Binding IsFemale}"/>
					</Grid>
				</Grid>

				<!-- Medication details — shown when checked -->
				<VerticalStackLayout IsVisible="{Binding TakingMedications}" Spacing="0">
					<Label Text="Medication details" Style="{StaticResource FormFieldLabel}"/>
					<Border Style="{StaticResource FormInputBoxTall}">
						<Editor Text="{Binding MedicationDetails}" Style="{StaticResource FormEditor}"/>
					</Border>
				</VerticalStackLayout>

				<!-- Hospitalization details — shown when checked -->
				<VerticalStackLayout IsVisible="{Binding HasBeenHospitalized}" Spacing="0">
					<Label Text="Hospitalization details" Style="{StaticResource FormFieldLabel}"/>
					<Border Style="{StaticResource FormInputBoxTall}">
						<Editor Text="{Binding HospitalizationDetails}" Style="{StaticResource FormEditor}"/>
					</Border>
				</VerticalStackLayout>

				<!-- ══ ALLERGIES ══ -->
				<Label Text="ALLERGIES" Style="{StaticResource FormSectionHeader}"/>
				<Label Text="Check all that apply:" FontSize="12"
                       TextColor="{StaticResource TextMuted}" Margin="0,0,0,6"/>

				<Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="0" ColumnSpacing="0">
					<Grid Grid.Row="0" Grid.Column="0" ColumnDefinitions="Auto,*" ColumnSpacing="4">
						<CheckBox Grid.Column="0" IsChecked="{Binding HasAspirinAllergy}" Color="{StaticResource PrimaryGreen}"/>
						<Label Grid.Column="1" Text="Aspirin" Style="{StaticResource FormCheckLabel}"/>
					</Grid>
					<Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="Auto,*" ColumnSpacing="4">
						<CheckBox Grid.Column="0" IsChecked="{Binding HasLatexAllergy}" Color="{StaticResource PrimaryGreen}"/>
						<Label Grid.Column="1" Text="Latex" Style="{StaticResource FormCheckLabel}"/>
					</Grid>
					<Grid Grid.Row="1" Grid.Column="0" ColumnDefinitions="Auto,*" ColumnSpacing="4">
						<CheckBox Grid.Column="0" IsChecked="{Binding HasLocalAnestheticAllergy}" Color="{StaticResource PrimaryGreen}"/>
						<Label Grid.Column="1" Text="Local Anesthetic" Style="{StaticResource FormCheckLabel}"/>
					</Grid>
					<Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="Auto,*" ColumnSpacing="4">
						<CheckBox Grid.Column="0" IsChecked="{Binding HasPenicillinAllergy}" Color="{StaticResource PrimaryGreen}"/>
						<Label Grid.Column="1" Text="Penicillin" Style="{StaticResource FormCheckLabel}"/>
					</Grid>
					<Grid Grid.Row="2" Grid.Column="0" ColumnDefinitions="Auto,*" ColumnSpacing="4">
						<CheckBox Grid.Column="0" IsChecked="{Binding HasSulfaAllergy}" Color="{StaticResource PrimaryGreen}"/>
						<Label Grid.Column="1" Text="Sulfa" Style="{StaticResource FormCheckLabel}"/>
					</Grid>
				</Grid>

				<Label Text="Other" Style="{StaticResource FormFieldLabel}"/>
				<Border Style="{StaticResource FormInputBox}">
					<Entry Text="{Binding OtherAllergy}" Style="{StaticResource FormEntry}"/>
				</Border>

				<!-- ══ MEDICAL CONDITIONS ══ -->
				<Label Text="MEDICAL CONDITIONS" Style="{StaticResource FormSectionHeader}"/>
				<Label Text="Check all that apply:" FontSize="12"
                       TextColor="{StaticResource TextMuted}" Margin="0,0,0,6"/>

				<CollectionView ItemsSource="{Binding Conditions}">
					<CollectionView.ItemsLayout>
						<GridItemsLayout Orientation="Vertical" Span="2"
                                         HorizontalItemSpacing="4" VerticalItemSpacing="0"/>
					</CollectionView.ItemsLayout>
					<CollectionView.ItemTemplate>
						<DataTemplate x:DataType="vm:ConditionCheckItem">
							<Grid ColumnDefinitions="Auto,*" ColumnSpacing="4" Padding="0,2">
								<CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                          Color="{StaticResource PrimaryGreen}" VerticalOptions="Center"/>
								<Label Grid.Column="1" Text="{Binding ConditionName}"
                                       Style="{StaticResource FormCheckLabel}"/>
							</Grid>
						</DataTemplate>
					</CollectionView.ItemTemplate>
				</CollectionView>

				<Label Text="Other" Style="{StaticResource FormFieldLabel}"/>
				<Border Style="{StaticResource FormInputBox}">
					<Entry Text="{Binding OtherCondition}" Style="{StaticResource FormEntry}"/>
				</Border>

				<BoxView HeightRequest="8" BackgroundColor="Transparent"/>
			</VerticalStackLayout>
		</ScrollView>

		<Grid Grid.Row="1" Padding="20,10,20,24" BackgroundColor="{StaticResource PageBg}">
			<Button Text="Save Patient"
                    Command="{Binding SavePatientCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                    Style="{StaticResource PrimaryButtonStyle}"/>
		</Grid>
	</Grid>
</ContentPage>
