<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:ClinicApp.ViewModels.SupplyVM"
    x:Class="ClinicApp.Views.SupplyRelated.StockHistoryPage"
    x:DataType="vm:StockHistoryViewModel"
    Title="Stock History"
    Shell.TabBarIsVisible="False">

	<Grid RowDefinitions="Auto,*">

		<!-- Supply name + stock count banner -->
		<Frame Grid.Row="0" Padding="16,14" HasShadow="True"
               BackgroundColor="White" CornerRadius="0" Margin="0">
			<Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
				<Label Grid.Column="0"
                       Text="{Binding SupplyName}"
                       FontSize="17" FontAttributes="Bold" TextColor="Black"
                       VerticalOptions="Center"/>
				<Frame Grid.Column="1"
                       Padding="8,3" CornerRadius="8"
                       HasShadow="False" BorderColor="Transparent"
                       BackgroundColor="{Binding StockStatusColor}"
                       VerticalOptions="Center">
					<Label Text="{Binding StockStatus}"
                           FontSize="11" FontAttributes="Bold" TextColor="White"/>
				</Frame>
				<Label Grid.Column="2"
                       Text="{Binding StockDisplay}"
                       FontSize="15" FontAttributes="Bold"
                       TextColor="Black" VerticalOptions="Center"/>
			</Grid>
		</Frame>

		<!-- Full history table -->
		<Frame Grid.Row="1" Padding="16" HasShadow="False"
               BackgroundColor="White" Margin="0" CornerRadius="0">
			<VerticalStackLayout Spacing="10">

				<!-- Table header -->
				<Grid ColumnDefinitions="*,*,*">
					<Label Grid.Column="0" Text="Change"
                           FontAttributes="Bold" FontSize="12" TextColor="Gray"
                           HorizontalTextAlignment="Center"/>
					<Label Grid.Column="1" Text="Type"
                           FontAttributes="Bold" FontSize="12" TextColor="Gray"
                           HorizontalTextAlignment="Center"/>
					<Label Grid.Column="2" Text="Date"
                           FontAttributes="Bold" FontSize="12" TextColor="Gray"
                           HorizontalTextAlignment="Center"/>
				</Grid>

				<BoxView HeightRequest="1" Color="LightGray"/>

				<CollectionView ItemsSource="{Binding Logs}" SelectionMode="None">
					<CollectionView.ItemTemplate>
						<DataTemplate x:DataType="vm:StockLogRowViewModel">
							<Grid ColumnDefinitions="*,*,*" Padding="0,7">
								<Label Grid.Column="0"
                                       IsVisible="{Binding IsIncrease}"
                                       Text="{Binding ChangeDisplay}"
                                       FontAttributes="Bold" FontSize="13"
                                       TextColor="SeaGreen"
                                       HorizontalTextAlignment="Center"/>
								<Label Grid.Column="0"
                                       IsVisible="{Binding IsIncrease, Converter={StaticResource InvertedBoolConverter}}"
                                       Text="{Binding ChangeDisplay}"
                                       FontAttributes="Bold" FontSize="13"
                                       TextColor="Crimson"
                                       HorizontalTextAlignment="Center"/>
								<Label Grid.Column="1" Text="{Binding TypeDisplay}"
                                       FontSize="13" TextColor="Gray"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center"/>
								<Label Grid.Column="2" Text="{Binding DateDisplay}"
                                       FontSize="13" TextColor="Gray"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center"/>
							</Grid>
						</DataTemplate>
					</CollectionView.ItemTemplate>
				</CollectionView>

				<Label IsVisible="{Binding Logs.Count, Converter={StaticResource IntEqualZeroConverter}}"
                       Text="No stock history yet."
                       TextColor="Gray" FontSize="13"
                       HorizontalTextAlignment="Center" Margin="0,20"/>

			</VerticalStackLayout>
		</Frame>

	</Grid>
</ContentPage>
