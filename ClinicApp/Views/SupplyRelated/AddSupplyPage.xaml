<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:vm="clr-namespace:ClinicApp.ViewModels.SupplyVM"
    x:Class="ClinicApp.Views.SupplyRelated.AddSupplyPage"
    x:DataType="vm:AddSupplyViewModel"
    Title="{Binding PageTitle}"
    Shell.TabBarIsVisible="False">

	<Grid RowDefinitions="*,Auto">

		<ScrollView Grid.Row="0">
			<VerticalStackLayout Padding="16" Spacing="14">

				<!-- Item Name -->
				<Label Text="Item Name" FontAttributes="Bold" FontSize="14" TextColor="Black"/>
				<Entry Placeholder="e.g. Disposable Gloves"
                       Text="{Binding ItemName}"
                       ClearButtonVisibility="WhileEditing"/>
				<Label Text="{Binding NameError}"
                       FontSize="12" TextColor="Crimson"
                       IsVisible="{Binding NameError, Converter={StaticResource StringNotEmptyConverter}}"/>

				<!-- Quantity -->
				<Label Text="Quantity (pcs)" FontAttributes="Bold" FontSize="14" TextColor="Black"/>
				<Entry Placeholder="e.g. 50" Keyboard="Numeric"
                       Text="{Binding Quantity}"/>

				<!-- Size / Variant -->
				<Label Text="Size / Variant (optional)" FontAttributes="Bold" FontSize="14" TextColor="Black"/>
				<Entry Placeholder="e.g. Small, Medium, 250mg"
                       Text="{Binding SizeVariant}"/>

				<!-- Has Expiration -->
				<Grid ColumnDefinitions="*,Auto">
					<Label Grid.Column="0" Text="Has Expiration?" FontAttributes="Bold" FontSize="14"
                           TextColor="Black" VerticalTextAlignment="Center"/>
					<HorizontalStackLayout Grid.Column="1" Spacing="16">
						<RadioButton Content="Yes" Value="True" TextColor="Black"
                                     IsChecked="{Binding HasExpiration}"/>
						<RadioButton Content="No" Value="False" TextColor="Black"
                                     IsChecked="{Binding HasExpiration, Converter={StaticResource InvertedBoolConverter}}"/>
					</HorizontalStackLayout>
				</Grid>

				<!-- Expiration Date -->
				<VerticalStackLayout IsVisible="{Binding HasExpiration}" Spacing="6">
					<Label Text="Expiration Date" FontAttributes="Bold" FontSize="14" TextColor="Black"/>
					<DatePicker Date="{Binding ExpirationDate}" Format="MMMM dd, yyyy"
                                MinimumDate="{x:Static sys:DateTime.Today}"/>
				</VerticalStackLayout>

				<!-- Minimum Stock -->
				<Label Text="Minimum Stock (pcs)" FontAttributes="Bold" FontSize="14" TextColor="Black"/>
				<Entry Placeholder="e.g. 10" Keyboard="Numeric"
                       Text="{Binding MinimumStock}"/>
				<Label Text="You will be alerted when stock is at or below this level."
                       FontSize="12" TextColor="Gray"/>

			</VerticalStackLayout>
		</ScrollView>

		<!-- Action buttons -->
		<Grid Grid.Row="1" ColumnDefinitions="*,*" Padding="16,10" ColumnSpacing="12"
              BackgroundColor="White">
			<Button Grid.Column="0" Text="Cancel"
                    Command="{Binding CancelCommand}"
                    BackgroundColor="LightGray" TextColor="Black"/>
			<Button Grid.Column="1" Text="Save"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding CanSave}"/>
		</Grid>

	</Grid>
</ContentPage>
