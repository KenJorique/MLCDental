<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:vm="clr-namespace:ClinicApp.ViewModels.SupplyVM"
    x:Class="ClinicApp.Views.SupplyRelated.AddSupplyPage"
    x:DataType="vm:AddSupplyViewModel"
    Title="{Binding PageTitle}"
    Shell.TabBarIsVisible="False">

	<Grid RowDefinitions="*,Auto">

		<ScrollView Grid.Row="0">
			<VerticalStackLayout Padding="16" Spacing="14">

				<!-- Item Name -->
				<Label Text="Item Name" FontAttributes="Bold" FontSize="14" TextColor="Black"/>
				<Entry Placeholder="e.g. Disposable Gloves"
                       Text="{Binding ItemName}"
                       ClearButtonVisibility="WhileEditing"/>
				<Label Text="{Binding NameError}"
                       FontSize="12" TextColor="Crimson"
                       IsVisible="{Binding NameError, Converter={StaticResource StringNotEmptyConverter}}"/>

				<!-- Unit -->
				<Label Text="Unit" FontAttributes="Bold" FontSize="14" TextColor="Black"/>
				<Picker ItemsSource="{Binding UnitOptions}"
                        SelectedItem="{Binding SelectedUnit}"
                        HorizontalOptions="Fill"/>

				<!-- Pieces per Unit (hidden when Per Piece) -->
				<VerticalStackLayout IsVisible="{Binding ShowPiecesPerUnit}" Spacing="6">
					<Label Text="Pieces per Unit" FontAttributes="Bold" FontSize="14" TextColor="Black"/>
					<Entry Placeholder="e.g. 100" Keyboard="Numeric"
                           Text="{Binding PiecesPerUnit}"/>
					<Label Text="No. of pieces in one unit (e.g. 1 box = 100 pcs)."
                           FontSize="12" TextColor="Gray"/>
				</VerticalStackLayout>

				<!-- Quantity (hidden in edit mode) -->
				<VerticalStackLayout IsVisible="{Binding IsEditMode, Converter={StaticResource InvertedBoolConverter}}"
                                     Spacing="6">
					<Label Text="Quantity" FontAttributes="Bold" FontSize="14" TextColor="Black"/>
					<Entry Placeholder="e.g. 5" Keyboard="Numeric"
                           Text="{Binding UnitQuantity}"/>
					<Label Text="Number of units being added (e.g. 3 boxes)."
                           FontSize="12" TextColor="Gray"
                           IsVisible="{Binding ShowPiecesPerUnit}"/>
				</VerticalStackLayout>

				<!-- Has Expiration -->
				<Label Text="Has Expiration?" FontAttributes="Bold" FontSize="14" TextColor="Black"/>
				<HorizontalStackLayout Spacing="16">
					<RadioButton Content="Yes" Value="True" TextColor="Black"
                                 IsChecked="{Binding HasExpiration}"/>
					<RadioButton Content="No" Value="False" TextColor="Black"
                                 IsChecked="{Binding HasExpiration, Converter={StaticResource InvertedBoolConverter}}"/>
				</HorizontalStackLayout>

				<!-- Expiration Date -->
				<VerticalStackLayout IsVisible="{Binding HasExpiration}" Spacing="6">
					<Label Text="Expiration Date" FontAttributes="Bold" FontSize="14" TextColor="Black"/>
					<DatePicker Date="{Binding ExpirationDate}" Format="MMMM dd, yyyy"
                                MinimumDate="{x:Static sys:DateTime.Today}"/>
				</VerticalStackLayout>

				<!-- Minimum Stock -->
				<Label Text="Minimum Stock (pcs)" FontAttributes="Bold" FontSize="14" TextColor="Black"/>
				<Entry Placeholder="e.g. 10" Keyboard="Numeric"
                       Text="{Binding MinimumStock}"/>
				<Label Text="Alert will show when stock reaches this level."
                       FontSize="12" TextColor="Gray"/>

			</VerticalStackLayout>
		</ScrollView>

		<!-- Action buttons -->
		<Grid Grid.Row="1" ColumnDefinitions="*,*" Padding="16,10" ColumnSpacing="12"
              BackgroundColor="White">
			<Button Grid.Column="0" Text="Cancel"
                    Command="{Binding CancelCommand}"
                    BackgroundColor="LightGray" TextColor="Black"/>
			<Button Grid.Column="1" Text="Save"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding CanSave}"/>
		</Grid>

	</Grid>
</ContentPage>
