<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:ClinicApp.ViewModels.SupplyVM"
    x:Class="ClinicApp.Views.SupplyRelated.SupplyInfoPage"
    x:DataType="vm:SupplyInfoViewModel"
    Title=" "
    Shell.TabBarIsVisible="False">

	<Grid RowDefinitions="*,Auto">

		<ScrollView Grid.Row="0">
			<VerticalStackLayout Padding="14" Spacing="12">

				<!-- Supply Header: Name | Status badge | Qty -->
				<Frame Padding="16,14" HasShadow="True" BackgroundColor="White">
					<Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
						<Label Grid.Column="0"
                               Text="{Binding Supply.Name}"
                               FontSize="18" FontAttributes="Bold" TextColor="Black"
                               VerticalOptions="Center"/>
						<Frame Grid.Column="1"
                               Padding="8,3" CornerRadius="8"
                               HasShadow="False" BorderColor="Transparent"
                               BackgroundColor="{Binding StockStatusColor}"
                               VerticalOptions="Center">
							<Label Text="{Binding StockStatus}"
                                   FontSize="11" FontAttributes="Bold"
                                   TextColor="White"/>
						</Frame>
						<Label Grid.Column="2"
                               Text="{Binding StockDisplay}"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="Black" VerticalOptions="Center"/>
					</Grid>
				</Frame>

				<!-- Item Details -->
				<Frame Padding="16" HasShadow="True" BackgroundColor="White">
					<VerticalStackLayout Spacing="10">
						<Label Text="Item Details" FontAttributes="Bold" FontSize="15" TextColor="Black"/>
						<BoxView HeightRequest="1" Color="LightGray"/>
						<Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
							<Label Grid.Row="0" Grid.Column="0" Text="Size / Variant"
                                   TextColor="Gray" FontSize="13"/>
							<Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding Supply.SizeVariant}"
                                   FontAttributes="Bold" FontSize="13" TextColor="Black"
                                   HorizontalTextAlignment="End"/>
							<Label Grid.Row="1" Grid.Column="0" Text="Expiration"
                                   TextColor="Gray" FontSize="13"/>
							<Label Grid.Row="1" Grid.Column="1"
                                   Text="{Binding ExpirationDisplay}"
                                   FontAttributes="Bold" FontSize="13" TextColor="Black"
                                   HorizontalTextAlignment="End"/>
							<Label Grid.Row="2" Grid.Column="0" Text="Minimum Stock"
                                   TextColor="Gray" FontSize="13"/>
							<Label Grid.Row="2" Grid.Column="1"
                                   Text="{Binding Supply.MinimumStockPieces, StringFormat='{0} pcs'}"
                                   FontAttributes="Bold" FontSize="13" TextColor="Black"
                                   HorizontalTextAlignment="End"/>
						</Grid>
					</VerticalStackLayout>
				</Frame>

				<!-- Stock History (recent 4) -->
				<Frame Padding="16" HasShadow="True" BackgroundColor="White">
					<VerticalStackLayout Spacing="10">
						<Grid ColumnDefinitions="*,Auto">
							<Label Grid.Column="0" Text="Stock History"
                                   FontAttributes="Bold" FontSize="15" TextColor="Black"/>
							<Label Grid.Column="1" Text="View All ›"
                                   FontSize="13" TextColor="#2196F3"
                                   VerticalOptions="Center">
								<Label.GestureRecognizers>
									<TapGestureRecognizer Command="{Binding ViewAllLogsCommand}"/>
								</Label.GestureRecognizers>
							</Label>
						</Grid>
						<BoxView HeightRequest="1" Color="LightGray"/>

						<!-- Header -->
						<Grid ColumnDefinitions="*,*,*">
							<Label Grid.Column="0" Text="Change"
                                   FontAttributes="Bold" FontSize="12" TextColor="Gray"
                                   HorizontalTextAlignment="Center"/>
							<Label Grid.Column="1" Text="Type"
                                   FontAttributes="Bold" FontSize="12" TextColor="Gray"
                                   HorizontalTextAlignment="Center"/>
							<Label Grid.Column="2" Text="Date"
                                   FontAttributes="Bold" FontSize="12" TextColor="Gray"
                                   HorizontalTextAlignment="Center"/>
						</Grid>

						<!-- Rows -->
						<CollectionView ItemsSource="{Binding RecentLogs}" SelectionMode="None">
							<CollectionView.ItemTemplate>
								<DataTemplate x:DataType="vm:StockLogRowViewModel">
									<Grid ColumnDefinitions="*,*,*" Padding="0,5">
										<Label Grid.Column="0"
                                               IsVisible="{Binding IsIncrease}"
                                               Text="{Binding ChangeDisplay}"
                                               FontAttributes="Bold" FontSize="13"
                                               TextColor="SeaGreen"
                                               HorizontalTextAlignment="Center"/>
										<Label Grid.Column="0"
                                               IsVisible="{Binding IsIncrease, Converter={StaticResource InvertedBoolConverter}}"
                                               Text="{Binding ChangeDisplay}"
                                               FontAttributes="Bold" FontSize="13"
                                               TextColor="Crimson"
                                               HorizontalTextAlignment="Center"/>
										<Label Grid.Column="1" Text="{Binding TypeDisplay}"
                                               FontSize="13" TextColor="Gray"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center"/>
										<Label Grid.Column="2" Text="{Binding DateDisplay}"
                                               FontSize="13" TextColor="Gray"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center"/>
									</Grid>
								</DataTemplate>
							</CollectionView.ItemTemplate>
						</CollectionView>

						<Label IsVisible="{Binding Logs.Count, Converter={StaticResource IntEqualZeroConverter}}"
                               Text="No stock history yet."
                               TextColor="Gray" FontSize="13"
                               HorizontalTextAlignment="Center" Margin="0,8"/>
					</VerticalStackLayout>
				</Frame>

				<BoxView HeightRequest="20"/>
			</VerticalStackLayout>
		</ScrollView>

		<!-- Bottom bar -->
		<Grid Grid.Row="1" Padding="14,10" BackgroundColor="White">
			<Button Text="Adjust Stock"
                    Clicked="OnAdjustStockClicked"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    CornerRadius="8"/>
		</Grid>

	</Grid>

</ContentPage>
