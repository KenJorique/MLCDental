<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:ClinicApp.ViewModels.SupplyVM"
    x:Class="ClinicApp.Views.SupplyRelated.SupplyInfoPage"
    x:DataType="vm:SupplyInfoViewModel"
    Title=" "
    Shell.TabBarIsVisible="False">

	<Grid RowDefinitions="*,Auto" BackgroundColor="{StaticResource White}">

		<ScrollView Grid.Row="0">
			<VerticalStackLayout Padding="16" Spacing="12">

				<!-- Supply Header: Name | Status badge | Qty -->
				<Border Style="{StaticResource SupplyCardStyle}">
					<Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
						<Label Grid.Column="0"
                               Text="{Binding Supply.Name}"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{StaticResource Gray900}"
                               LineBreakMode="TailTruncation"
                               VerticalOptions="Center"/>
						<Border Grid.Column="1"
                                Style="{StaticResource SupplyStatusBadgeStyle}"
                                BackgroundColor="{Binding StockStatusColor}"
                                VerticalOptions="Center">
							<Label Text="{Binding StockStatus}"
                                   Style="{StaticResource SupplyStatusBadgeLabelStyle}"/>
						</Border>
						<Label Grid.Column="2"
                               Text="{Binding StockDisplay}"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource Gray900}"
                               VerticalOptions="Center"/>
					</Grid>
				</Border>

				<!-- Item Details -->
				<Border Style="{StaticResource SupplyCardStyle}">
					<VerticalStackLayout Spacing="10">
						<Label Text="Item Details" Style="{StaticResource SupplySectionTitleStyle}"/>
						<BoxView HeightRequest="1" Color="{StaticResource Gray100}"/>
						<Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="10">

							<Label Grid.Row="0" Grid.Column="0" Text="Unit"
                                   Style="{StaticResource SupplyRowLabelStyle}"/>
							<Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding UnitDisplay}"
                                   Style="{StaticResource SupplyRowValueStyle}"/>

							<Label Grid.Row="1" Grid.Column="0" Text="Expiration"
                                   Style="{StaticResource SupplyRowLabelStyle}"/>
							<Label Grid.Row="1" Grid.Column="1"
                                   Text="{Binding ExpirationDisplay}"
                                   Style="{StaticResource SupplyRowValueStyle}"/>

							<Label Grid.Row="2" Grid.Column="0" Text="Minimum Stock"
                                   Style="{StaticResource SupplyRowLabelStyle}"/>
							<Label Grid.Row="2" Grid.Column="1"
                                   Text="{Binding Supply.MinimumStockPieces, StringFormat='{0} pcs'}"
                                   Style="{StaticResource SupplyRowValueStyle}"/>

						</Grid>
					</VerticalStackLayout>
				</Border>

				<!-- Stock History (recent 4) -->
				<Border Style="{StaticResource SupplyCardStyle}">
					<VerticalStackLayout Spacing="10">
						<Grid ColumnDefinitions="*,Auto">
							<Label Grid.Column="0" Text="Stock History"
                                   Style="{StaticResource SupplySectionTitleStyle}"/>
							<Label Grid.Column="1" Text="View All ›"
                                   Style="{StaticResource SupplyLinkStyle}"
                                   VerticalOptions="Center">
								<Label.GestureRecognizers>
									<TapGestureRecognizer Command="{Binding ViewAllLogsCommand}"/>
								</Label.GestureRecognizers>
							</Label>
						</Grid>
						<BoxView HeightRequest="1" Color="{StaticResource Gray100}"/>

						<!-- Header -->
						<Grid ColumnDefinitions="*,*,*">
							<Label Grid.Column="0" Text="Change"
                                   Style="{StaticResource SupplyCaptionStyle}"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"/>
							<Label Grid.Column="1" Text="Type"
                                   Style="{StaticResource SupplyCaptionStyle}"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"/>
							<Label Grid.Column="2" Text="Date"
                                   Style="{StaticResource SupplyCaptionStyle}"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"/>
						</Grid>

						<!-- Rows -->
						<CollectionView ItemsSource="{Binding RecentLogs}" SelectionMode="None">
							<CollectionView.ItemTemplate>
								<DataTemplate x:DataType="vm:StockLogRowViewModel">
									<Grid ColumnDefinitions="*,*,*" Padding="0,6">
										<Label Grid.Column="0"
                                               IsVisible="{Binding IsIncrease}"
                                               Text="{Binding ChangeDisplay}"
                                               FontAttributes="Bold" FontSize="13"
                                               TextColor="{StaticResource StatusGood}"
                                               HorizontalTextAlignment="Center"/>
										<Label Grid.Column="0"
                                               IsVisible="{Binding IsIncrease, Converter={StaticResource InvertedBoolConverter}}"
                                               Text="{Binding ChangeDisplay}"
                                               FontAttributes="Bold" FontSize="13"
                                               TextColor="{StaticResource StatusOut}"
                                               HorizontalTextAlignment="Center"/>
										<Label Grid.Column="1" Text="{Binding TypeDisplay}"
                                               Style="{StaticResource SupplyCaptionStyle}"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center"/>
										<Label Grid.Column="2" Text="{Binding DateDisplay}"
                                               Style="{StaticResource SupplyCaptionStyle}"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center"/>
									</Grid>
								</DataTemplate>
							</CollectionView.ItemTemplate>
						</CollectionView>

						<Label IsVisible="{Binding Logs.Count, Converter={StaticResource IntEqualZeroConverter}}"
                               Text="No stock history yet."
                               Style="{StaticResource SupplyCaptionStyle}"
                               HorizontalTextAlignment="Center" Margin="0,8"/>
					</VerticalStackLayout>
				</Border>

			</VerticalStackLayout>
		</ScrollView>

		<!-- Bottom bar -->
		<Grid Grid.Row="1" Padding="16,12" BackgroundColor="{StaticResource White}">
			<Button Text="Adjust Stock"
                    Clicked="OnAdjustStockClicked"
                    Style="{StaticResource SupplyPrimaryButtonStyle}"/>
		</Grid>

	</Grid>

</ContentPage>
