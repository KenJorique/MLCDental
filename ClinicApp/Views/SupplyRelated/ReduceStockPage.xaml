<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:ClinicApp.ViewModels.SupplyVM"
    x:Class="ClinicApp.Views.SupplyRelated.ReduceStockPage"
    x:DataType="vm:ReduceStockViewModel"
    Title="Reduce Stock"
    Shell.TabBarIsVisible="False">

	<Grid RowDefinitions="*,Auto">

		<ScrollView Grid.Row="0">
			<VerticalStackLayout Padding="16" Spacing="14">

				<!-- Quantity to Reduce -->
				<Label Text="Quantity to Reduce (pcs)" FontAttributes="Bold" FontSize="14" TextColor="Black"/>
				<Entry Placeholder="e.g. 10" Keyboard="Numeric"
                       Text="{Binding ReduceQty}"/>
				<Label Text="{Binding MaxAvailableText}"
                       FontSize="12" TextColor="Gray"/>
				<Label Text="{Binding QtyError}"
                       FontSize="12" TextColor="Crimson"
                       IsVisible="{Binding QtyError, Converter={StaticResource StringNotEmptyConverter}}"/>

				<!-- Type dropdown -->
				<Label Text="Type" FontAttributes="Bold" FontSize="14" TextColor="Black"/>
				<Picker ItemsSource="{Binding TypeOptions}"
                        SelectedItem="{Binding SelectedType}"
                        Title="Select type"
                        TextColor="Black"/>

			</VerticalStackLayout>
		</ScrollView>

		<!-- Action buttons -->
		<Grid Grid.Row="1" ColumnDefinitions="*,*" Padding="16,10" ColumnSpacing="12"
              BackgroundColor="White">
			<Button Grid.Column="0" Text="Cancel"
                    Command="{Binding CancelCommand}"
                    BackgroundColor="LightGray" TextColor="Black"/>
			<Button Grid.Column="1" Text="Save"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="#2196F3" TextColor="White"/>
		</Grid>

	</Grid>
</ContentPage>
