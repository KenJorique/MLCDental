<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:ClinicApp.ViewModels.SupplyVM"
    x:Class="ClinicApp.Views.SupplyRelated.ReduceStockPage"
    x:DataType="vm:ReduceStockViewModel"
    Title="Reduce Stock"
    BackgroundColor="{StaticResource PageBg}"
    Shell.TabBarIsVisible="False">

	<Grid RowDefinitions="*,Auto">
		<ScrollView Grid.Row="0">
			<VerticalStackLayout Padding="20,4,20,8" Spacing="0">

				<Label Text="Quantity to Reduce (pcs)" Style="{StaticResource FormFieldLabel}"/>
				<Border Style="{StaticResource FormInputBox}">
					<Entry Text="{Binding ReduceQty}" Keyboard="Numeric"
                           Placeholder="e.g. 10"
                           Style="{StaticResource FormEntry}"/>
				</Border>
				<Label Text="{Binding MaxAvailableText}" Style="{StaticResource FormHintLabel}"/>
				<Label Text="{Binding QtyError}"
                       Style="{StaticResource FormErrorLabel}"
                       IsVisible="{Binding QtyError, Converter={StaticResource StringNotEmptyConverter}}"/>

				<Label Text="Reduction Type" Style="{StaticResource FormFieldLabel}"/>
				<Border Style="{StaticResource FormInputBox}">
					<Picker ItemsSource="{Binding TypeOptions}"
                            SelectedItem="{Binding SelectedType}"
                            Title="Select type"
                            FontSize="14" BackgroundColor="Transparent"
                            VerticalOptions="Center"/>
				</Border>

			</VerticalStackLayout>
		</ScrollView>

		<Grid Grid.Row="1" ColumnDefinitions="*,*" Padding="20,10,20,24"
              ColumnSpacing="12" BackgroundColor="{StaticResource PageBg}">
			<Button Grid.Column="0" Text="Cancel"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource SupplySecondaryButtonStyle}"/>
			<Button Grid.Column="1" Text="Save"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource SupplyPrimaryButtonStyle}"/>
		</Grid>
	</Grid>
</ContentPage>
