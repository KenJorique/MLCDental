<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:vm="clr-namespace:ClinicApp.ViewModels.SupplyVM"
    x:Class="ClinicApp.Views.SupplyRelated.AddStockPage"
    x:DataType="vm:AddStockViewModel"
    Title="Add Stock"
    BackgroundColor="{StaticResource PageBg}"
    Shell.TabBarIsVisible="False">

	<Grid RowDefinitions="*,Auto">
		<ScrollView Grid.Row="0">
			<VerticalStackLayout Padding="20,4,20,8" Spacing="0">

				<Label Text="Quantity to Add (pcs)" Style="{StaticResource FormFieldLabel}"/>
				<Border Style="{StaticResource FormInputBox}">
					<Entry Text="{Binding AddQty}" Keyboard="Numeric"
                           Placeholder="e.g. 50"
                           Style="{StaticResource FormEntry}"/>
				</Border>
				<Label Text="{Binding QtyError}"
                       Style="{StaticResource FormErrorLabel}"
                       IsVisible="{Binding QtyError, Converter={StaticResource StringNotEmptyConverter}}"/>

				<Label Text="Expiration Date" Style="{StaticResource FormFieldLabel}"/>
				<Border Style="{StaticResource FormInputBox}">
					<DatePicker Date="{Binding ExpirationDate}"
                                Format="MMMM dd, yyyy"
                                MinimumDate="{x:Static sys:DateTime.Today}"
                                IsEnabled="{Binding HasExpirationParam}"
                                FontSize="14"
                                TextColor="{StaticResource TextPrimary}"
                                BackgroundColor="Transparent"
                                VerticalOptions="Center"/>
				</Border>
				<Label Text="This item does not track an expiration date."
                       Style="{StaticResource FormHintLabel}"
                       IsVisible="{Binding HasExpirationParam, Converter={StaticResource InvertedBoolConverter}}"/>

			</VerticalStackLayout>
		</ScrollView>

		<Grid Grid.Row="1" ColumnDefinitions="*,*" Padding="20,10,20,24"
              ColumnSpacing="12" BackgroundColor="{StaticResource PageBg}">
			<Button Grid.Column="0" Text="Cancel"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource SupplySecondaryButtonStyle}"/>
			<Button Grid.Column="1" Text="Save"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource SupplyPrimaryButtonStyle}"/>
		</Grid>
	</Grid>
</ContentPage>
