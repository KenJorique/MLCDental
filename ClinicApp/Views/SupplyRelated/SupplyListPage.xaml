<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:ClinicApp.ViewModels.SupplyVM"
    x:Class="ClinicApp.Views.SupplyRelated.SupplyListPage"
    x:DataType="vm:SupplyListViewModel"
    Title="Medical Supply"
    Shell.NavBarIsVisible="True"
    Shell.BackgroundColor="{StaticResource PrimaryPink}"
    Shell.TitleColor="White"
    Shell.ForegroundColor="White"
    Shell.TabBarIsVisible="False"
    BackgroundColor="{StaticResource PageBg}">

	<Grid RowDefinitions="Auto,Auto,*">

		<!-- ── SEARCH + FILTER BAR ── -->
		<VerticalStackLayout Grid.Row="0"
                             BackgroundColor="{StaticResource PrimaryPink}"
                             Padding="16,0,16,14">
			<Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
				<Border Grid.Column="0"
                        BackgroundColor="White"
                        StrokeThickness="0"
                        HeightRequest="40">
					<Border.StrokeShape>
						<RoundRectangle CornerRadius="20"/>
					</Border.StrokeShape>
					<Grid ColumnDefinitions="Auto,*" Padding="12,0" ColumnSpacing="8">
						<Label Grid.Column="0"
                               FontFamily="MaterialSymbolsRounded"
                               Text="&#xe8b6;"
                               FontSize="17"
                               TextColor="{StaticResource TextMuted}"
                               VerticalOptions="Center"/>
						<Entry Grid.Column="1"
                               Text="{Binding SearchText}"
                               Placeholder="Search supplies..."
                               PlaceholderColor="{StaticResource TextMuted}"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="13"
                               BackgroundColor="Transparent"
                               VerticalOptions="Center"/>
					</Grid>
				</Border>

				<Border Grid.Column="1"
                        BackgroundColor="Transparent"
                        StrokeThickness="0"
                        HeightRequest="40" WidthRequest="40"
                        VerticalOptions="Center">
					<Border.GestureRecognizers>
						<TapGestureRecognizer Command="{Binding ShowSortOptionsCommand}"/>
					</Border.GestureRecognizers>
					<Label FontFamily="MaterialSymbolsRounded"
                           Text="&#xef4f;"
                           FontSize="24"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
				</Border>
			</Grid>
		</VerticalStackLayout>

		<!-- ── LOW STOCK BANNER ── -->
		<Border Grid.Row="1"
                IsVisible="{Binding HasLowStock}"
                BackgroundColor="#FFF3E0"
                Stroke="#FFB74D"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 10"
                Padding="12,8"
                Margin="16,8,16,0">
			<Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
				<Label Grid.Column="0"
                       FontFamily="MaterialSymbolsRounded"
                       Text="&#xe002;"
                       FontSize="16"
                       TextColor="#E65100"
                       VerticalOptions="Center"/>
				<Label Grid.Column="1"
                       Text="{Binding LowStockSummary}"
                       FontSize="13" FontAttributes="Bold"
                       TextColor="#E65100"
                       VerticalOptions="Center"/>
			</Grid>
		</Border>

		<!-- ── SUPPLY LIST ── -->
		<CollectionView Grid.Row="2"
                        ItemsSource="{Binding FilteredCards}"
                        SelectionMode="None"
                        Margin="16,8,16,88"
                        IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}">

			<CollectionView.EmptyView>
				<VerticalStackLayout Spacing="8"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Margin="0,60,0,0">
					<Label Text="No supplies found"
                           Style="{StaticResource SupplyEmptyTitleStyle}"/>
					<Label Text="Tap + to add your first supply item"
                           Style="{StaticResource SupplyEmptySubtitleStyle}"/>
				</VerticalStackLayout>
			</CollectionView.EmptyView>

			<CollectionView.ItemTemplate>
				<DataTemplate x:DataType="vm:SupplyCardViewModel">
					<Border Style="{StaticResource SupplyListRowCardStyle}">
						<Border.GestureRecognizers>
							<TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                          Path=BindingContext.ShowActionSheetCommand}"
                                CommandParameter="{Binding .}"/>
						</Border.GestureRecognizers>

						<Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
							<VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
								<Label Text="{Binding Supply.Name}"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"
                                       LineBreakMode="TailTruncation"/>
								<Label Text="{Binding UnitDisplay}"
                                       Style="{StaticResource SupplyCaptionStyle}"/>
							</VerticalStackLayout>

							<Border Grid.Column="1"
                                    Style="{StaticResource SupplyStatusBadgeStyle}"
                                    BackgroundColor="{Binding StockStatusColor}"
                                    VerticalOptions="Center">
								<Label Text="{Binding StockStatusLabel}"
                                       Style="{StaticResource SupplyStatusBadgeLabelStyle}"/>
							</Border>

							<Label Grid.Column="2"
                                   Text="{Binding StockDisplay}"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   VerticalOptions="Center"/>
						</Grid>
					</Border>
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>

		<!-- Loading -->
		<VerticalStackLayout Grid.Row="2"
                             IsVisible="{Binding IsBusy}"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Spacing="8">
			<ActivityIndicator IsRunning="{Binding IsBusy}"
                               Color="{StaticResource PrimaryPink}"
                               HeightRequest="36" WidthRequest="36"/>
			<Label Text="Loading supplies..."
                   Style="{StaticResource SupplyCaptionStyle}"
                   HorizontalTextAlignment="Center"/>
		</VerticalStackLayout>

		<!-- FAB -->
		<Button Grid.Row="2"
                Text="+ Add Item"
                Command="{Binding GoToAddSupplyCommand}"
                Style="{StaticResource FabStyle}"
                VerticalOptions="End"
                HorizontalOptions="End"
                Margin="0,0,20,24"/>

	</Grid>
</ContentPage>
