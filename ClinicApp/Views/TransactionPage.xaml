<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ClinicApp.ViewModels"
             xmlns:models="clr-namespace:ClinicApp.Models"
             x:Class="ClinicApp.Views.TransactionPage"
             BackgroundColor="#F5F5F5">

    <ContentPage.Title>
        <Binding Path="PatientName" StringFormat="Transactions — {0}"/>
    </ContentPage.Title>

    <Grid>
        <RefreshView Command="{Binding RefreshCommand}"
                     IsRefreshing="{Binding IsRefreshing}">
            <ScrollView>
                <VerticalStackLayout Padding="16" Spacing="12">

                    <!-- Summary card -->
                    <Frame BackgroundColor="#4A4A8A" BorderColor="#4A4A8A"
                           CornerRadius="12" Padding="16" HasShadow="False">
                        <Grid ColumnDefinitions="*,*,*">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="Total Billed" FontSize="11"
                                       TextColor="#B0B0D0"/>
                                <Label Text="{Binding TotalDue, StringFormat='₱{0:N2}'}"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="White"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4"
                                HorizontalOptions="Center">
                                <Label Text="Total Paid" FontSize="11"
                                       TextColor="#B0B0D0"/>
                                <Label Text="{Binding TotalPaid, StringFormat='₱{0:N2}'}"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="#90EE90"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" Spacing="4"
                                HorizontalOptions="End">
                                <Label Text="Balance" FontSize="11"
                                       TextColor="#B0B0D0"/>
                                <Label Text="{Binding TotalBalance, StringFormat='₱{0:N2}'}"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="#FFB347"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>

                    <!-- Add treatment button -->
                    <Button Text="+ Add Treatment Record"
                            BackgroundColor="#4A4A8A"
                            TextColor="White"
                            CornerRadius="10"
                            HeightRequest="44"
                            FontSize="13"
                            Command="{Binding OpenAddTreatmentCommand}"/>

                    <!-- Treatment history -->
                    <Label Text="Service History" FontSize="14"
                           FontAttributes="Bold" TextColor="#333"
                           Margin="0,8,0,0"/>

                    <Label Text="No service records yet"
                           FontSize="12" TextColor="#999"
                           IsVisible="{Binding TreatmentRecords.Count,
                               Converter={StaticResource IntEqualZeroConverter}}"/>

                    <CollectionView ItemsSource="{Binding TreatmentRecords}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:SupabaseTreatmentRecord">
                                <Frame Margin="0,0,0,8" Padding="12"
                                       CornerRadius="10" HasShadow="False"
                                       BackgroundColor="White"
                                       BorderColor="#E0E0E0">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="{Binding ServiceName}"
                                                   FontSize="14" FontAttributes="Bold"
                                                   TextColor="#222"/>
                                            <Label Text="{Binding VisitDate,
                                                       StringFormat='{0:MMM dd, yyyy}'}"
                                                   FontSize="11" TextColor="#888"/>
                                            <Label Text="{Binding Notes}"
                                                   FontSize="11" TextColor="#666"
                                                   IsVisible="{Binding Notes,
                                                       Converter={StaticResource StringNotEmptyConverter}}"/>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1"
                                               Text="{Binding ServicePrice, StringFormat='₱{0:N2}'}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="#4A4A8A"
                                               VerticalOptions="Center"/>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Transaction history -->
                    <Label Text="Payment History" FontSize="14"
                           FontAttributes="Bold" TextColor="#333"
                           Margin="0,8,0,0"/>

                    <Label Text="No transactions yet"
                           FontSize="12" TextColor="#999"
                           IsVisible="{Binding Transactions.Count,
                               Converter={StaticResource IntEqualZeroConverter}}"/>

                    <CollectionView ItemsSource="{Binding Transactions}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:SupabaseTransaction">
                                <Frame Margin="0,0,0,8" Padding="12"
                                       CornerRadius="10" HasShadow="False"
                                       BackgroundColor="{Binding StatusBgColor}"
                                       BorderColor="{Binding StatusColor}">
                                    <Grid RowDefinitions="Auto,Auto,Auto"
                                          ColumnDefinitions="*,Auto">

                                        <Label Grid.Row="0" Grid.Column="0"
                                               Text="{Binding ServiceName}"
                                               FontSize="14" FontAttributes="Bold"
                                               TextColor="#222"/>

                                        <Border Grid.Row="0" Grid.Column="1"
                                                BackgroundColor="{Binding StatusColor}"
                                                StrokeShape="RoundRectangle 6"
                                                Stroke="Transparent"
                                                Padding="6,2">
                                            <Label Text="{Binding StatusLabel}"
                                                   FontSize="10" FontAttributes="Bold"
                                                   TextColor="White"/>
                                        </Border>

                                        <Label Grid.Row="1" Grid.Column="0"
                                               Grid.ColumnSpan="2"
                                               FontSize="12" TextColor="#555"
                                               Margin="0,4,0,0">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="Billed: "/>
                                                    <Span Text="{Binding TotalDisplay}"
                                                          FontAttributes="Bold"/>
                                                    <Span Text="   Paid: "/>
                                                    <Span Text="{Binding PaidDisplay}"
                                                          TextColor="#2E7D32"
                                                          FontAttributes="Bold"/>
                                                    <Span Text="   Balance: "/>
                                                    <Span Text="{Binding BalanceDisplay}"
                                                          TextColor="#C62828"
                                                          FontAttributes="Bold"/>
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>

                                        <Label Grid.Row="2" Grid.Column="0"
                                               Text="{Binding VisitDateDisplay}"
                                               FontSize="11" TextColor="#888"
                                               Margin="0,4,0,0"/>

                                        <Button Grid.Row="2" Grid.Column="1"
                                                Text="Pay"
                                                BackgroundColor="#4A4A8A"
                                                TextColor="White"
                                                CornerRadius="8"
                                                FontSize="12"
                                                HeightRequest="32"
                                                Padding="12,0"
                                                IsVisible="{Binding PaymentStatus,
                                                    Converter={StaticResource StringNotEqualConverter},
                                                    ConverterParameter=paid}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                          Path=BindingContext.OpenPaymentCommand}"
                                                CommandParameter="{Binding .}"/>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <BoxView HeightRequest="80" Color="Transparent"/>
                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>

        <!-- Add Treatment overlay -->
        <Grid IsVisible="{Binding ShowAddTreatment}"
              BackgroundColor="#80000000" ZIndex="10">
            <Frame Margin="16,100,16,100" CornerRadius="16"
                   Padding="0" BackgroundColor="White" HasShadow="False">
                <Grid RowDefinitions="Auto,*,Auto">

                    <Grid Grid.Row="0" BackgroundColor="#4A4A8A"
                          Padding="14,10" ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Add Treatment Record"
                               FontSize="14" FontAttributes="Bold"
                               TextColor="White" VerticalOptions="Center"/>
                        <Button Grid.Column="1" Text="✕"
                                BackgroundColor="Transparent"
                                TextColor="White" FontSize="16"
                                WidthRequest="36" HeightRequest="36" Padding="0"
                                Command="{Binding CloseAddTreatmentCommand}"/>
                    </Grid>

                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout Padding="16" Spacing="12">

                            <Label Text="Service / Procedure"
                                   FontSize="12" TextColor="#888"/>
                            <Entry Text="{Binding SelectedService}"
                                   Placeholder="e.g. Tooth Extraction, Cleaning"
                                   FontSize="14"/>

                            <Label Text="Price (₱)"
                                   FontSize="12" TextColor="#888"/>
                            <Entry Text="{Binding ServicePrice}"
                                   Keyboard="Numeric"
                                   Placeholder="0.00"
                                   FontSize="14"/>

                            <Label Text="Notes (optional)"
                                   FontSize="12" TextColor="#888"/>
                            <Editor Text="{Binding VisitNotes}"
                                    Placeholder="Any notes about this visit..."
                                    HeightRequest="80" FontSize="13"/>

                        </VerticalStackLayout>
                    </ScrollView>

                    <VerticalStackLayout Grid.Row="2" Padding="16,12" Spacing="8">
                        <Button Text="Save Treatment Record"
                                BackgroundColor="#4A4A8A" TextColor="White"
                                CornerRadius="10" HeightRequest="44" FontSize="13"
                                Command="{Binding SaveTreatmentRecordCommand}"/>
                    </VerticalStackLayout>

                </Grid>
            </Frame>
        </Grid>

        <!-- Payment overlay -->
        <Grid IsVisible="{Binding ShowPaymentForm}"
              BackgroundColor="#80000000" ZIndex="10">
            <Frame Margin="16,160,16,160" CornerRadius="16"
                   Padding="0" BackgroundColor="White" HasShadow="False">
                <Grid RowDefinitions="Auto,*,Auto">

                    <Grid Grid.Row="0" BackgroundColor="#2E7D32"
                          Padding="14,10" ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Record Payment"
                               FontSize="14" FontAttributes="Bold"
                               TextColor="White" VerticalOptions="Center"/>
                        <Button Grid.Column="1" Text="✕"
                                BackgroundColor="Transparent"
                                TextColor="White" FontSize="16"
                                WidthRequest="36" HeightRequest="36" Padding="0"
                                Command="{Binding ClosePaymentCommand}"/>
                    </Grid>

                    <VerticalStackLayout Grid.Row="1" Padding="16" Spacing="12">

                        <Frame BackgroundColor="#F5F5F5" BorderColor="#E0E0E0"
                               CornerRadius="10" Padding="12">
                            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                                <Label Grid.Row="0"
                                       Text="{Binding SelectedTransaction.ServiceName}"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="#222"/>
                                <Label Grid.Row="1" FontSize="13" TextColor="#555">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Total: "/>
                                            <Span Text="{Binding SelectedTransaction.TotalDisplay}"
                                                  FontAttributes="Bold"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label Grid.Row="2" FontSize="14"
                                       TextColor="#C62828" FontAttributes="Bold">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Outstanding Balance: "/>
                                            <Span Text="{Binding SelectedTransaction.BalanceDisplay}"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </Grid>
                        </Frame>

                        <Label Text="Amount to Pay (₱)"
                               FontSize="12" TextColor="#888"/>
                        <Entry Text="{Binding PaymentAmount}"
                               Keyboard="Numeric"
                               FontSize="16" FontAttributes="Bold"
                               PlaceholderColor="#CCC"/>

                        <Label Text="Payment method: Cash"
                               FontSize="12" TextColor="#888"
                               HorizontalOptions="Center"/>

                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Row="2" Padding="16,12" Spacing="8">
                        <Button Text="Confirm Payment"
                                BackgroundColor="#2E7D32" TextColor="White"
                                CornerRadius="10" HeightRequest="44" FontSize="13"
                                Command="{Binding RecordPaymentCommand}"/>
                    </VerticalStackLayout>

                </Grid>
            </Frame>
        </Grid>

    </Grid>
</ContentPage>