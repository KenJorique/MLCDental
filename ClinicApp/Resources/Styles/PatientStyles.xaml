<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

	<!-- ══════════════════════════════════════════
         UNIFIED COLOR PALETTE (pastel pink theme)
         Used across PatientListPage + PatientDetailsPage
    ══════════════════════════════════════════════ -->

	<!-- Pink scale -->
	<Color x:Key="PrimaryPink">#C4607A</Color>
	<!-- main accent — medium rose -->
	<Color x:Key="LightPink">#FAEDF1</Color>
	<!-- button/card tint -->
	<Color x:Key="MediumPink">#F0C4D0</Color>
	<!-- folder tab, borders -->
	<Color x:Key="HeaderPink">#D4768E</Color>
	<!-- page header bar -->

	<!-- Backgrounds -->
	<Color x:Key="PageBg">#FFFFFF</Color>
	<Color x:Key="SurfaceBg">#FBF4F7</Color>
	<!-- input background -->
	<Color x:Key="CardBg">#FFFFFF</Color>

	<!-- Text -->
	<Color x:Key="TextPrimary">#1A1A2E</Color>
	<Color x:Key="TextSecondary">#6B7280</Color>
	<Color x:Key="TextMuted">#B0B7C3</Color>
	<Color x:Key="TextOnPrimary">#FFFFFF</Color>

	<!-- Borders & Dividers -->
	<Color x:Key="BorderColor">#F0E4EA</Color>
	<Color x:Key="Divider">#F5EBF0</Color>
	<Color x:Key="CardBorder">#F0C4D0</Color>

	<!-- ══════════════════════════════════════════
         TYPOGRAPHY
    ══════════════════════════════════════════════ -->
	<Style x:Key="SectionTitleStyle" TargetType="Label">
		<Setter Property="FontSize" Value="12"/>
		<Setter Property="FontAttributes" Value="Bold"/>
		<Setter Property="TextColor" Value="{StaticResource PrimaryPink}"/>
		<Setter Property="Margin" Value="0,0,0,12"/>
	</Style>

	<Style x:Key="RowLabelStyle" TargetType="Label">
		<Setter Property="FontSize" Value="14"/>
		<Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
		<Setter Property="VerticalOptions" Value="Center"/>
	</Style>

	<Style x:Key="RowValueStyle" TargetType="Label">
		<Setter Property="FontSize" Value="14"/>
		<Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
		<Setter Property="FontAttributes" Value="Bold"/>
		<Setter Property="VerticalOptions" Value="Center"/>
		<Setter Property="HorizontalTextAlignment" Value="End"/>
		<Setter Property="LineBreakMode" Value="WordWrap"/>
	</Style>

	<Style x:Key="BodyStyle" TargetType="Label">
		<Setter Property="FontSize" Value="14"/>
		<Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
	</Style>

	<Style x:Key="CaptionStyle" TargetType="Label">
		<Setter Property="FontSize" Value="12"/>
		<Setter Property="TextColor" Value="{StaticResource TextMuted}"/>
	</Style>

	<!-- ══════════════════════════════════════════
         CARDS
    ══════════════════════════════════════════════ -->
	<Style x:Key="CardStyle" TargetType="Border">
		<Setter Property="BackgroundColor" Value="{StaticResource CardBg}"/>
		<Setter Property="Stroke" Value="{StaticResource CardBorder}"/>
		<Setter Property="StrokeThickness" Value="1"/>
		<Setter Property="Padding" Value="16"/>
		<Setter Property="Margin" Value="0,0,0,12"/>
	</Style>

	<Style x:Key="DetailCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}"/>

	<!-- ══════════════════════════════════════════
         INPUTS
    ══════════════════════════════════════════════ -->
	<Style x:Key="EntryStyle" TargetType="Entry">
		<Setter Property="FontSize" Value="14"/>
		<Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
		<Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}"/>
		<Setter Property="MinimumHeightRequest" Value="44"/>
		<Setter Property="BackgroundColor" Value="Transparent"/>
	</Style>

	<!-- ══════════════════════════════════════════
         BUTTONS
    ══════════════════════════════════════════════ -->
	<Style x:Key="PrimaryButtonStyle" TargetType="Button">
		<Setter Property="BackgroundColor" Value="{StaticResource PrimaryPink}"/>
		<Setter Property="TextColor" Value="{StaticResource TextOnPrimary}"/>
		<Setter Property="FontSize" Value="16"/>
		<Setter Property="FontAttributes" Value="Bold"/>
		<Setter Property="CornerRadius" Value="14"/>
		<Setter Property="HeightRequest" Value="52"/>
		<Setter Property="HorizontalOptions" Value="Fill"/>
	</Style>

	<Style x:Key="FabStyle" TargetType="Button">
		<Setter Property="BackgroundColor" Value="{StaticResource PrimaryPink}"/>
		<Setter Property="TextColor" Value="{StaticResource TextOnPrimary}"/>
		<Setter Property="CornerRadius" Value="28"/>
		<Setter Property="Padding" Value="20,12"/>
		<Setter Property="FontAttributes" Value="Bold"/>
		<Setter Property="FontSize" Value="14"/>
	</Style>

	<Style x:Key="SortButtonStyle" TargetType="Button">
		<Setter Property="BackgroundColor" Value="{StaticResource CardBg}"/>
		<Setter Property="TextColor" Value="{StaticResource PrimaryPink}"/>
		<Setter Property="BorderColor" Value="{StaticResource CardBorder}"/>
		<Setter Property="BorderWidth" Value="1"/>
		<Setter Property="CornerRadius" Value="12"/>
		<Setter Property="FontSize" Value="13"/>
		<Setter Property="FontAttributes" Value="Bold"/>
	</Style>

	<!-- ══════════════════════════════════════════
         PATIENT LIST PAGE
    ══════════════════════════════════════════════ -->

	<!-- Patient name label -->
	<Style x:Key="PatientNameStyle" TargetType="Label">
		<Setter Property="FontSize" Value="15"/>
		<Setter Property="FontAttributes" Value="Bold"/>
		<Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
		<Setter Property="LineBreakMode" Value="TailTruncation"/>
	</Style>

	<!-- PatientCardStyle kept for Frame-based cards -->
	<Style x:Key="PatientCardStyle" TargetType="Frame">
		<Setter Property="BackgroundColor" Value="{StaticResource CardBg}"/>
		<Setter Property="BorderColor" Value="{StaticResource CardBorder}"/>
		<Setter Property="CornerRadius" Value="12"/>
		<Setter Property="HasShadow" Value="False"/>
		<Setter Property="Padding" Value="16"/>
		<Setter Property="Margin" Value="0"/>
	</Style>

	<!-- 2x2 section button (enabled) -->
	<Style x:Key="SectionButtonStyle" TargetType="Frame">
		<Setter Property="BackgroundColor" Value="{StaticResource LightPink}"/>
		<Setter Property="BorderColor" Value="{StaticResource MediumPink}"/>
		<Setter Property="CornerRadius" Value="10"/>
		<Setter Property="HasShadow" Value="False"/>
		<Setter Property="Padding" Value="12,10"/>
		<Setter Property="HeightRequest" Value="52"/>
	</Style>

	<!-- 2x2 section button label -->
	<Style x:Key="SectionButtonLabelStyle" TargetType="Label">
		<Setter Property="FontSize" Value="12"/>
		<Setter Property="TextColor" Value="{StaticResource PrimaryPink}"/>
		<Setter Property="FontAttributes" Value="Bold"/>
		<Setter Property="LineBreakMode" Value="WordWrap"/>
		<Setter Property="VerticalOptions" Value="Center"/>
	</Style>

</ResourceDictionary>
