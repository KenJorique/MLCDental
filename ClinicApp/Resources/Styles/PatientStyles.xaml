<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

	<!-- ══════════════════════════════════════════
         MLC CLINIC — GREEN PALETTE
         Used across all pages. Keep in sync with Colors.xaml.
         NOTE: Keys previously named "Pink" have been renamed to
         accurate green names. Find+Replace in all pages:
           PrimaryGreen  → PrimaryGreen
           LightGreen    → LightGreen
           MediumGreen   → MediumGreen
           PrimaryGreen   → PrimaryGreen
    ══════════════════════════════════════════════ -->

	<!-- Brand greens -->
	<Color x:Key="PrimaryGreen">#1A6B2F</Color>
	<Color x:Key="LightGreen">#EAF4EC</Color>
	<Color x:Key="MediumGreen">#B8DEC0</Color>

	<!-- Backgrounds -->
	<Color x:Key="PageBg">#FFFFFF</Color>
	<Color x:Key="SurfaceBg">#F0F7F1</Color>
	<Color x:Key="CardBg">#FFFFFF</Color>

	<!-- Text -->
	<Color x:Key="TextPrimary">#1A1A2E</Color>
	<Color x:Key="TextSecondary">#6B7280</Color>
	<Color x:Key="TextMuted">#B0B7C3</Color>
	<Color x:Key="TextOnPrimary">#FFFFFF</Color>

	<!-- Borders & Dividers -->
	<Color x:Key="BorderColor">#C4DEC9</Color>
	<Color x:Key="Divider">#DCF0E2</Color>
	<Color x:Key="CardBorder">#C4DEC9</Color>

	<!-- ══════════════════════════════════════════
         TYPOGRAPHY
    ══════════════════════════════════════════════ -->
	<Style x:Key="SectionTitleStyle" TargetType="Label">
		<Setter Property="FontSize" Value="12"/>
		<Setter Property="FontAttributes" Value="Bold"/>
		<Setter Property="TextColor" Value="{StaticResource PrimaryGreen}"/>
		<Setter Property="Margin" Value="0,0,0,12"/>
	</Style>

	<Style x:Key="RowLabelStyle" TargetType="Label">
		<Setter Property="FontSize" Value="14"/>
		<Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
		<Setter Property="VerticalOptions" Value="Center"/>
	</Style>

	<Style x:Key="RowValueStyle" TargetType="Label">
		<Setter Property="FontSize" Value="14"/>
		<Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
		<Setter Property="FontAttributes" Value="Bold"/>
		<Setter Property="VerticalOptions" Value="Center"/>
		<Setter Property="HorizontalTextAlignment" Value="End"/>
		<Setter Property="LineBreakMode" Value="WordWrap"/>
	</Style>

	<Style x:Key="BodyStyle" TargetType="Label">
		<Setter Property="FontSize" Value="14"/>
		<Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
	</Style>

	<Style x:Key="CaptionStyle" TargetType="Label">
		<Setter Property="FontSize" Value="12"/>
		<Setter Property="TextColor" Value="{StaticResource TextMuted}"/>
	</Style>

	<!-- ══════════════════════════════════════════
         CARDS
    ══════════════════════════════════════════════ -->
	<Style x:Key="CardStyle" TargetType="Border">
		<Setter Property="BackgroundColor" Value="{StaticResource CardBg}"/>
		<Setter Property="Stroke" Value="{StaticResource CardBorder}"/>
		<Setter Property="StrokeThickness" Value="1"/>
		<Setter Property="Padding" Value="16"/>
		<Setter Property="Margin" Value="0,0,0,12"/>
	</Style>

	<Style x:Key="DetailCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}"/>

	<!-- ══════════════════════════════════════════
         INPUTS
    ══════════════════════════════════════════════ -->
	<Style x:Key="EntryStyle" TargetType="Entry">
		<Setter Property="FontSize" Value="14"/>
		<Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
		<Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}"/>
		<Setter Property="MinimumHeightRequest" Value="44"/>
		<Setter Property="BackgroundColor" Value="Transparent"/>
		<Setter Property="Keyboard" Value="Text"/>
	</Style>

	<!-- ══════════════════════════════════════════
         BUTTONS
    ══════════════════════════════════════════════ -->
	<Style x:Key="PrimaryButtonStyle" TargetType="Button">
		<Setter Property="BackgroundColor" Value="{StaticResource PrimaryGreen}"/>
		<Setter Property="TextColor" Value="{StaticResource TextOnPrimary}"/>
		<Setter Property="FontSize" Value="16"/>
		<Setter Property="FontAttributes" Value="Bold"/>
		<Setter Property="CornerRadius" Value="14"/>
		<Setter Property="HeightRequest" Value="52"/>
		<Setter Property="HorizontalOptions" Value="Fill"/>
	</Style>

	<Style x:Key="FabStyle" TargetType="Button">
		<Setter Property="BackgroundColor" Value="{StaticResource PrimaryGreen}"/>
		<Setter Property="TextColor" Value="{StaticResource TextOnPrimary}"/>
		<Setter Property="CornerRadius" Value="28"/>
		<Setter Property="Padding" Value="20,12"/>
		<Setter Property="FontAttributes" Value="Bold"/>
		<Setter Property="FontSize" Value="14"/>
	</Style>

	<Style x:Key="SortButtonStyle" TargetType="Button">
		<Setter Property="BackgroundColor" Value="{StaticResource CardBg}"/>
		<Setter Property="TextColor" Value="{StaticResource PrimaryGreen}"/>
		<Setter Property="BorderColor" Value="{StaticResource CardBorder}"/>
		<Setter Property="BorderWidth" Value="1"/>
		<Setter Property="CornerRadius" Value="12"/>
		<Setter Property="FontSize" Value="13"/>
		<Setter Property="FontAttributes" Value="Bold"/>
	</Style>

	<!-- ══════════════════════════════════════════
         PATIENT LIST
    ══════════════════════════════════════════════ -->
	<Style x:Key="PatientNameStyle" TargetType="Label">
		<Setter Property="FontSize" Value="15"/>
		<Setter Property="FontAttributes" Value="Bold"/>
		<Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
		<Setter Property="LineBreakMode" Value="TailTruncation"/>
	</Style>

	<Style x:Key="PatientCardStyle" TargetType="Frame">
		<Setter Property="BackgroundColor" Value="{StaticResource CardBg}"/>
		<Setter Property="BorderColor" Value="{StaticResource CardBorder}"/>
		<Setter Property="CornerRadius" Value="12"/>
		<Setter Property="HasShadow" Value="False"/>
		<Setter Property="Padding" Value="16"/>
		<Setter Property="Margin" Value="0"/>
	</Style>

	<Style x:Key="SectionButtonStyle" TargetType="Frame">
		<Setter Property="BackgroundColor" Value="{StaticResource LightGreen}"/>
		<Setter Property="BorderColor" Value="{StaticResource MediumGreen}"/>
		<Setter Property="CornerRadius" Value="10"/>
		<Setter Property="HasShadow" Value="False"/>
		<Setter Property="Padding" Value="12,10"/>
		<Setter Property="HeightRequest" Value="52"/>
	</Style>

	<Style x:Key="SectionButtonLabelStyle" TargetType="Label">
		<Setter Property="FontSize" Value="12"/>
		<Setter Property="TextColor" Value="{StaticResource PrimaryGreen}"/>
		<Setter Property="FontAttributes" Value="Bold"/>
		<Setter Property="LineBreakMode" Value="WordWrap"/>
		<Setter Property="VerticalOptions" Value="Center"/>
	</Style>

</ResourceDictionary>
